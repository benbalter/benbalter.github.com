    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@textlint-rule/textlint-rule-no-duplicate-abbr": "^1.0.2",
    "@textlint-rule/textlint-rule-no-unmatched-pair": "^2.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.1",
    "astro": "^6.1.8",
    "astro-compress": "^2.4.0",
    "astro-favicons": "^3.1.6",
    "dictionary-en": "^4.0.0",
    "eslint": "^10.1.0",
    "gray-matter": "^4.0.3",
    "happy-dom": "^20.8.9",
    "image-size": "^2.0.2",
    "markdownlint-cli2-formatter-pretty": "^0.0.10",
    "pagefind": "^1.4.0",
    "rehype-accessible-emojis": "^0.3.2",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-cli": "^12.0.1",
    "remark-emoji": "^5.0.2",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mentions": "^1.1.0",
    "remark-parse": "^11.0.0",
    "remark-preset-lint-consistent": "^6.0.1",
    "remark-preset-lint-markdown-style-guide": "^6.0.1",
    "remark-preset-lint-recommended": "^7.0.1",
    "remark-rehype": "^11.1.2",
    "remark-retext": "^6.0.1",
    "remark-smartypants": "^3.0.2",
    "remark-textr": "^6.1.0",
    "remark-validate-links": "^13.1.0",
    "retext-contractions": "^6.0.0",
    "retext-english": "^5.0.0",
    "retext-equality": "^7.1.0",
    "retext-indefinite-article": "^5.0.0",
    "retext-intensify": "^7.0.0",
    "retext-passive": "^5.0.0",
    "retext-readability": "^8.0.0",
    "retext-redundant-acronyms": "^5.0.0",
    "retext-repeated-words": "^5.0.0",
    "retext-sentence-spacing": "^6.0.0",
    "retext-simplify": "^8.0.0",
    "retext-spell": "^6.1.0",
    "retext-stringify": "^4.0.0",
    "schema-dts": "^2.0.0",
    "tailwindcss": "^4.2.2",
    "textlint": "^15.5.2",
    "textlint-rule-common-misspellings": "^1.0.1",
    "textlint-rule-diacritics": "^2.1.4",
    "textlint-rule-doubled-spaces": "^1.0.2",
    "textlint-rule-no-start-duplicated-conjunction": "^2.0.2",
    "textlint-rule-stop-words": "^5.2.0",
    "textlint-rule-terminology": "^5.2.16",
    "textlint-rule-write-good": "^2.0.0",
    "typescript": "^6.0.2",
    "typographic-arrows": "^1.0.3",
    "typographic-copyright": "^1.0.1",
    "typographic-em-dashes": "^1.0.2",
    "typographic-en-dashes": "^1.0.1",
    "typographic-math-symbols": "^1.1.5",
    "typographic-registered-trademark": "^1.0.1",
    "typographic-single-spaces": "^1.0.2",
    "typographic-trademark": "^1.0.1",
    "unified": "^11.0.5",
    "vitest": "^4.1.1",
    "wrangler": "^4.79.0",
    "xo": "^2.0.2"
  },
  "homepage": "https://github.com/benbalter/benbalter.github.com#readme",
  "license": "CC-BY-3.0",
  "main": "astro.config.mjs",
  "name": "benbalter.github.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benbalter/benbalter.github.com.git"
  },
  "scripts": {
    "build": "astro build && script/inject-modulepreload && script/inject-image-size && pagefind --site dist-astro",
    "dev": "astro dev",
    "preview": "astro preview",
    "check": "astro check --tsconfig tsconfig.astro.json",
    "validate-seo": "tsx script/validate-seo.ts",
    "lint": "npm run lint-js && npm run lint-json && npm run lint-md",
    "lint-js": "eslint .remarkrc.js --fix",
    "lint-json": "eslint --fix '**/*.json'",
    "lint-md": "remark . && markdownlint-cli2 --fix \"**/*.{md,mdx}\" \"!node_modules\" \"!.github\"",
    "lint-text": "textlint *.md src/content/posts/*.md src/content/resume-positions/*.md --fix --dry-run",
    "lint-yaml": "yamllint -c .yamllint.yml .github/workflows/ .github/dependabot.yml src/data/*.yml .yamllint.yml .markdown-lint.yml",
    "super-linter": "script/super-linter",
    "test": "npm run check && npm run lint && npm run test:vitest",
    "test:e2e": "playwright test",
    "test:e2e:accessibility": "playwright test e2e/accessibility-astro.spec.ts",
    "test:e2e:performance": "playwright test e2e/performance-astro.spec.ts",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:vitest": "vitest run",
    "test:vitest:watch": "vitest",
    "test:vitest:ui": "vitest --ui",
    "test:vitest:coverage": "vitest run --coverage"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "version": "1.0.0",
  "overrides": {
    "eslint-config-xo-react": {
      "eslint-plugin-react": {
        "eslint": "$eslint"
      },
      "eslint-plugin-react-hooks": {
        "eslint": "$eslint"
      }
    },
    "typescript": "$typescript"
  }
}
