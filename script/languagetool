#!/bin/sh

set -e

LANGUAGETOOL_URL="${LANGUAGETOOL_URL:-http://localhost:8010}"

# Check if LanguageTool server is available
if ! curl -sf "${LANGUAGETOOL_URL}/v2/languages" > /dev/null 2>&1; then
	echo "LanguageTool server not available at ${LANGUAGETOOL_URL}. Skipping."
	echo "To run LanguageTool locally, see:"
	echo "https://ben.balter.com/2025/01/30/how-to-run-language-tool-open-source-grammarly-alternative-on-macos/"
	exit 0
fi

echo "Running LanguageTool grammar checker..."

# Rules disabled to avoid false positives from Markdown syntax
# and overlap with existing prose linters (retext-spell, textlint, etc.)
DISABLED_RULES="MORFOLOGIK_RULE_EN_US"           # Spelling (handled by retext-spell)
DISABLED_RULES="${DISABLED_RULES},EN_A_VS_AN"     # a/an (handled by retext-indefinite-article)
DISABLED_RULES="${DISABLED_RULES},ENGLISH_WORD_REPEAT_RULE" # Repeated words (handled by retext-repeated-words)
DISABLED_RULES="${DISABLED_RULES},UPPERCASE_SENTENCE_START" # Code terms may start sentences
DISABLED_RULES="${DISABLED_RULES},WHITESPACE_RULE"          # Markdown formatting artifacts
DISABLED_RULES="${DISABLED_RULES},COMMA_PARENTHESIS_WHITESPACE" # Markdown link syntax
DISABLED_RULES="${DISABLED_RULES},EN_UNPAIRED_BRACKETS"     # Markdown brackets for links/refs
DISABLED_RULES="${DISABLED_RULES},UNLIKELY_OPENING_PUNCTUATION" # Markdown formatting
DISABLED_RULES="${DISABLED_RULES},SENTENCE_FRAGMENT"        # Headings and list items
DISABLED_RULES="${DISABLED_RULES},PUNCTUATION_PARAGRAPH_END" # Code blocks at paragraph end
DISABLED_RULES="${DISABLED_RULES},DOUBLE_PUNCTUATION"       # Footnote syntax
DISABLED_RULES="${DISABLED_RULES},ARROWS"                   # Handled by remark-textr
DISABLED_RULES="${DISABLED_RULES},CONSECUTIVE_SPACES"       # Markdown stripping artifacts
DISABLED_RULES="${DISABLED_RULES},ENGLISH_WORD_REPEAT_BEGINNING_RULE" # Lists repeat sentence starts
DISABLED_RULES="${DISABLED_RULES},EN_UNPAIRED_QUOTES"       # Markdown formatting artifacts
DISABLED_RULES="${DISABLED_RULES},COMMA_PERIOD"             # Markdown footnote syntax artifacts

# Compound/hyphenation rules (author's established open-compound style)
DISABLED_RULES="${DISABLED_RULES},DECISION_MAKING"
DISABLED_RULES="${DISABLED_RULES},TO_DO_HYPHEN"
DISABLED_RULES="${DISABLED_RULES},CROSS_COMPOUNDS"
DISABLED_RULES="${DISABLED_RULES},NOUN_VERB_CONFUSION"      # opt-in as verb
DISABLED_RULES="${DISABLED_RULES},MISSING_HYPHEN"
DISABLED_RULES="${DISABLED_RULES},MUCH_NEEDED_HYPHEN"
DISABLED_RULES="${DISABLED_RULES},WRITE_UP_HYPHEN"
DISABLED_RULES="${DISABLED_RULES},HOUR_HYPHEN"
DISABLED_RULES="${DISABLED_RULES},A_HEADS_UP"
DISABLED_RULES="${DISABLED_RULES},SETUP_VERB"
DISABLED_RULES="${DISABLED_RULES},LOG_IN"
DISABLED_RULES="${DISABLED_RULES},EN_COMPOUNDS_BRAIN_STORMING"
DISABLED_RULES="${DISABLED_RULES},EN_COMPOUNDS_COLOR_BLIND"
DISABLED_RULES="${DISABLED_RULES},EN_COMPOUNDS_CROWD_SOURCED"
DISABLED_RULES="${DISABLED_RULES},EN_COMPOUNDS_DOUBLE_SPEAK"
DISABLED_RULES="${DISABLED_RULES},EN_COMPOUNDS_FORWARD_THINKING"
DISABLED_RULES="${DISABLED_RULES},EN_COMPOUNDS_FUTURE_PROOF"
DISABLED_RULES="${DISABLED_RULES},EN_COMPOUNDS_INTER_OFFICE"
DISABLED_RULES="${DISABLED_RULES},EN_COMPOUNDS_MID_DAY"
DISABLED_RULES="${DISABLED_RULES},EN_COMPOUNDS_NIT_PICKS"
DISABLED_RULES="${DISABLED_RULES},EN_COMPOUNDS_OFF_TOPIC"
DISABLED_RULES="${DISABLED_RULES},EN_COMPOUNDS_PLATFORM_AGNOSTIC"
DISABLED_RULES="${DISABLED_RULES},EN_COMPOUNDS_SELF_PRESERVATION"
DISABLED_RULES="${DISABLED_RULES},EN_COMPOUNDS_SIDE_BAR"
DISABLED_RULES="${DISABLED_RULES},EN_COMPOUNDS_SIGNAL_TO_NOISE"
DISABLED_RULES="${DISABLED_RULES},EN_COMPOUNDS_THOUGHT_PROVOKING"
DISABLED_RULES="${DISABLED_RULES},EN_COMPOUNDS_TIME_CONSUMING"
DISABLED_RULES="${DISABLED_RULES},EN_COMPOUNDS_WELL_DEFINED"

# Comma and punctuation style rules
DISABLED_RULES="${DISABLED_RULES},COMMA_COMPOUND_SENTENCE"
DISABLED_RULES="${DISABLED_RULES},COMMA_COMPOUND_SENTENCE_2"
DISABLED_RULES="${DISABLED_RULES},COMMA_AFTER_A_MONTH"
DISABLED_RULES="${DISABLED_RULES},SENT_START_CONJUNCTIVE_LINKING_ADVERB_COMMA"
DISABLED_RULES="${DISABLED_RULES},MISSING_COMMA_AFTER_INTRODUCTORY_PHRASE"
DISABLED_RULES="${DISABLED_RULES},BY_DEFAULT_COMMA"
DISABLED_RULES="${DISABLED_RULES},ETC_PERIOD"
DISABLED_RULES="${DISABLED_RULES},SENTENCE_WHITESPACE"
DISABLED_RULES="${DISABLED_RULES},LC_AFTER_PERIOD"

# Agreement rules (false positives in complex prose)
DISABLED_RULES="${DISABLED_RULES},AGREEMENT_SENT_START"
DISABLED_RULES="${DISABLED_RULES},AGREEMENT_SENT_START_2"
DISABLED_RULES="${DISABLED_RULES},BASE_FORM"
DISABLED_RULES="${DISABLED_RULES},A_NNS"
DISABLED_RULES="${DISABLED_RULES},THE_NN_AND_THE_NN"
DISABLED_RULES="${DISABLED_RULES},MANY_NN"
DISABLED_RULES="${DISABLED_RULES},PCT_SINGULAR_NOUN_PLURAL_VERB_AGREEMENT"
DISABLED_RULES="${DISABLED_RULES},PRP_VB"
DISABLED_RULES="${DISABLED_RULES},PRP_PAST_PART"
DISABLED_RULES="${DISABLED_RULES},A_RB_NN"
DISABLED_RULES="${DISABLED_RULES},IF_IS"
DISABLED_RULES="${DISABLED_RULES},THERE_IS_A_LOT_OF"
DISABLED_RULES="${DISABLED_RULES},THERE_S_MANY"

# Style preference rules
DISABLED_RULES="${DISABLED_RULES},SUBJECT_MATTER"
DISABLED_RULES="${DISABLED_RULES},WHETHER"
DISABLED_RULES="${DISABLED_RULES},COMPRISED_OF"
DISABLED_RULES="${DISABLED_RULES},PREFER_OVER_TO"
DISABLED_RULES="${DISABLED_RULES},IN_A_X_MANNER"
DISABLED_RULES="${DISABLED_RULES},EQUALLY_AS"
DISABLED_RULES="${DISABLED_RULES},ASK_THE_QUESTION"
DISABLED_RULES="${DISABLED_RULES},GENERAL_XX"
DISABLED_RULES="${DISABLED_RULES},PAST_EXPERIENCE_MEMORY"
DISABLED_RULES="${DISABLED_RULES},IT_IS"
DISABLED_RULES="${DISABLED_RULES},IT_IS_2"
DISABLED_RULES="${DISABLED_RULES},IN_THE_MOMENT"

# Pronoun/possessive and other rules
DISABLED_RULES="${DISABLED_RULES},ITS_TO_IT_S"
DISABLED_RULES="${DISABLED_RULES},TO_VB_ITS_NN"
DISABLED_RULES="${DISABLED_RULES},POSSESSIVE_APOSTROPHE"
DISABLED_RULES="${DISABLED_RULES},LETS_LET"
DISABLED_RULES="${DISABLED_RULES},DOCTORS_APPOINTMENT"
DISABLED_RULES="${DISABLED_RULES},CC_VERB"
DISABLED_RULES="${DISABLED_RULES},NON_STANDARD_WORD"
DISABLED_RULES="${DISABLED_RULES},GOOGLE_PRODUCTS"
DISABLED_RULES="${DISABLED_RULES},EN_SPECIFIC_CASE"
DISABLED_RULES="${DISABLED_RULES},RATHER_THEN"

errors=0
files_checked=0

# Content files to check
CONTENT_FILES="src/content/posts/*.md src/content/posts/*.mdx"

for file in $CONTENT_FILES; do
	# Skip if glob didn't match any files
	[ -e "$file" ] || continue

	# Extract plain text: strip frontmatter, code blocks, imports, inline code, HTML, URLs
	text=$(awk '
		NR==1 && /^---$/ { in_fm=1; next }
		in_fm && /^---$/ { in_fm=0; next }
		in_fm { next }
		/^```/ { in_code=!in_code; next }
		in_code { next }
		/^import .* from / { next }
		{ print }
	' "$file" | \
		sed -E \
		    -e 's/`[^`]*`/CODE/g' \
		    -e 's/<[^>]*>//g' \
		    -e 's/!\[[^]]*\]\([^)]*\)//g' \
		    -e 's/\[\^[^]]*\]//g' \
		    -e 's/\[([^]]*)\]\([^)]*\)/ \1 /g' \
		    -e 's/^#{1,6} //' \
		    -e 's/\*\*//g' \
		    -e 's/\*//g' \
		    -e 's/^[-*+] //' \
		    -e 's/^[0-9]+\. //' | \
		sed -e 's/  */ /g' -e 's/^ //')

	# Skip empty files (e.g., all code)
	if [ -z "$(echo "$text" | tr -d '[:space:]')" ]; then
		continue
	fi

	files_checked=$((files_checked + 1))

	# Write text to temp file for safe curl usage
	tmpfile=$(mktemp)
	chmod 600 "$tmpfile"
	echo "$text" > "$tmpfile"

	response=$(curl -s -X POST "${LANGUAGETOOL_URL}/v2/check" \
		--data-urlencode "text@${tmpfile}" \
		-d "language=en-US" \
		-d "disabledRules=${DISABLED_RULES}") || true

	rm -f "$tmpfile"

	matches=$(echo "$response" | jq '.matches | length' 2>/dev/null) || matches=0

	if [ "$matches" -gt 0 ]; then
		echo ""
		echo "=== ${file}: ${matches} issue(s) ==="
		echo "$response" | jq -r '.matches[] | "  [\(.rule.id)] \(.message)\n    Context: \"\(.context.text)\"\n"'
		errors=$((errors + matches))
	fi
done

echo ""
echo "Checked ${files_checked} file(s)."

if [ "$errors" -gt 0 ]; then
	echo "Total: ${errors} issue(s) found."
	exit 1
fi

echo "No issues found."
