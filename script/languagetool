DISABLED_RULES="${DISABLED_RULES},SHORT_CUT"
DISABLED_RULES="${DISABLED_RULES},TO_DO_HYPHEN"
DISABLED_RULES="${DISABLED_RULES},HOUR_HYPHEN"
DISABLED_RULES="${DISABLED_RULES},WEEK_LONG_HYPHEN"
