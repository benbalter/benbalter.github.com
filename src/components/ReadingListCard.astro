---
/**
 * ReadingListCard component - Renders a single post as a visually rich numbered card
 *
 * Designed for curated reading list contexts where posts should feel
 * like a hand-picked collection rather than a flat bullet list.
 *
 * Props:
 * - title: The post title
 * - description: Plain-text description (already stripped of markdown)
 * - url: The post URL path
 * - index: 1-based index for numbering (displayed as "01", "02", etc.)
 */

interface Props {
  title: string;
  description: string;
  url: string;
  index: number;
}

const { title, description, url, index } = Astro.props;
const formattedIndex = String(index).padStart(2, '0');
---

<article class="reading-list-card not-prose group relative flex gap-4 rounded-lg border border-gray-200 bg-white p-5 border-l-4 border-l-primary-200 transition-all duration-200 hover:shadow-md hover:border-l-primary motion-safe:hover:-translate-y-0.5 dark:border-gray-700 dark:bg-gray-800 dark:border-l-primary-700 dark:hover:border-l-primary-400">
  <div class="select-none text-3xl font-bold leading-none text-gray-200 dark:text-gray-700" aria-hidden="true">
    {formattedIndex}
  </div>
  <div class="min-w-0 flex-1">
    <h3 class="text-base font-semibold leading-snug m-0">
      <a href={url} class="text-gray-900 no-underline hover:text-primary dark:text-gray-100 dark:hover:text-primary-300 before:absolute before:inset-0">
        {title}
      </a>
    </h3>
    {description && (
      <p class="mt-1 mb-0 text-sm leading-relaxed text-gray-600 dark:text-gray-300">
        {description}
      </p>
    )}
  </div>
</article>
