---
/**
 * FeatureCard Component
 * 
 * Display a feature or service with an emoji icon, title, and description.
 * Used on the about page and other marketing/informational pages.
 *
 * Props:
 * - emoji: Icon emoji to display at the top
 * - title: Feature title
 * - description: Feature description text
 *
 * Usage:
 * <FeatureCard 
 *   emoji="🚀" 
 *   title="Fast" 
 *   description="Lightning-fast performance" 
 * />
 */

interface Props {
  emoji: string;
  title: string;
  description: string;
}

const { emoji, title, description } = Astro.props;
---

<div class="not-prose rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-5 h-full transition-all duration-200 motion-safe:hover:-translate-y-0.5 hover:shadow-md dark:hover:shadow-[0_4px_8px_rgba(255,255,255,0.1)]">
  <div class="text-4xl mb-3" aria-hidden="true">{emoji}</div>
  <h3 class="text-primary dark:text-primary-300 mt-0 mb-2 text-lg font-semibold">{title}</h3>
  <p class="text-gray-600 dark:text-gray-300 leading-relaxed m-0 text-sm">{description}</p>
</div>
