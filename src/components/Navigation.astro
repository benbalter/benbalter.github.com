---
/**
 * Navigation Component
 * 
 * Site-wide navigation bar with active state highlighting.
 * Matches the structure and styling of the Jekyll navigation.
 * Uses Tailwind CSS for styling.
 */

import { siteConfig } from '../config';

interface Props {
  hero?: boolean;
}

interface NavItem {
  title: string;
  url: string;
}

const { hero = false } = Astro.props;

// Define navigation items (matching Jekyll's nav_pages)
const navItems: NavItem[] = [
  { title: 'Posts', url: '/' },
  { title: 'About', url: '/about/' },
  { title: 'Contact', url: '/contact/' },
];

// Get current path for active state
const currentPath = Astro.url.pathname;
const isPostPage = /^\d{4}\/\d{2}\/\d{2}\//.test(currentPath.slice(1));

function isNavActive(itemUrl: string): boolean {
  if (itemUrl === '/') return currentPath === '/' || isPostPage;
  return currentPath.startsWith(itemUrl);
}

// Base classes for navbar
const baseClasses = "navbar flex flex-wrap items-center justify-between py-3 px-4 bg-gray-100/95 dark:bg-gray-800/95 backdrop-blur-sm border border-gray-200 dark:border-gray-700 shadow-sm mb-4 max-md:mb-2";

// Conditionally add rounded classes based on hero presence
// For hero pages: round only bottom corners (top-left and top-right are 0)
// For non-hero pages: round all corners
const navClasses = hero 
  ? `${baseClasses} rounded-t-none rounded-b-lg border-t-0`
  : `${baseClasses} rounded-lg`;
---

<nav class={navClasses} aria-label="Main navigation" transition:persist="nav" data-has-hero={hero}>
  <script>
    // Update active nav link state and border styling on page transitions
    document.addEventListener('astro:page-load', () => {
      const currentPath = window.location.pathname;
      const navLinks = document.querySelectorAll('[data-nav-links] .nav-link');
      
      // Update active link state
      navLinks.forEach((link) => {
        const href = link.getAttribute('href');
        const isPostPage = /^\/\d{4}\/\d{2}\/\d{2}\//.test(currentPath);
        const isActive = currentPath === href ||
          (href === '/' && isPostPage) ||
          (href !== '/' && href !== null && currentPath.startsWith(href));
        
        // Active classes
        link.classList.toggle('active', isActive);
        link.classList.toggle('text-gray-900', isActive);
        link.classList.toggle('dark:text-gray-100', isActive);
        link.classList.toggle('font-semibold', isActive);
        // Inactive classes
        link.classList.toggle('text-primary-800', !isActive);
        link.classList.toggle('dark:text-primary-300', !isActive);
        link.classList.toggle('hover:text-primary-900', !isActive);
        link.classList.toggle('dark:hover:text-primary-200', !isActive);
        
        if (isActive) {
          link.setAttribute('aria-current', 'page');
        } else {
          link.removeAttribute('aria-current');
        }
      });
      
      // Update navigation border/rounded corners based on whether new page has hero
      const nav = document.querySelector('nav.navbar');
      const heroElement = document.querySelector('.hero-unit');
      const hasHero = heroElement !== null;
      
      if (nav) {
        nav.setAttribute('data-has-hero', String(hasHero));
        
        if (hasHero) {
          nav.classList.remove('rounded-lg');
          nav.classList.add('rounded-t-none', 'rounded-b-lg', 'border-t-0');
        } else {
          nav.classList.remove('rounded-t-none', 'rounded-b-lg', 'border-t-0');
          nav.classList.add('rounded-lg');
        }
      }
    });
  </script>
  <div class="flex flex-wrap items-center w-full">
    <!-- Left side: Brand + Nav links -->
    <div class="flex items-center flex-grow">
      <a class="navbar-brand font-bold text-gray-900 dark:text-gray-100 no-underline min-h-[44px] flex items-center tracking-tight transition-colors duration-200 hover:text-primary dark:hover:text-primary-400 pb-2 text-lg whitespace-nowrap shrink-0" href="/">{siteConfig.name}</a>
      
      <!-- Nav links (visible on desktop, left-aligned after brand) -->
      <div class="nav-collapse navbar-collapse md:flex md:items-center" id="navbar">
        <ul data-nav-links class="flex flex-col md:flex-row list-none p-0 m-0">
          {navItems.map((item) => {
            const isActive = isNavActive(item.url);
            return (
              <li class="nav-item relative" data-text={item.title}>
                <a 
                  href={item.url} 
                  class={`nav-link px-4 py-3 flex items-center min-h-[44px] transition-colors duration-200 no-underline ${isActive ? 'active text-gray-900 dark:text-gray-100 font-semibold' : 'text-primary-800 dark:text-primary-300 hover:text-primary-900 dark:hover:text-primary-200'}`}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {item.title}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    </div>
    
    <!-- Right side: Search + Tagline + Mobile toggle -->
    <div class="flex items-center">
      <button
        data-search-open
        type="button"
        class="p-2 rounded text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-primary-300 hover:bg-primary/5 dark:hover:bg-primary/10 transition-colors duration-200 min-h-[44px] min-w-[44px] flex items-center justify-center"
        aria-label="Search (⌘K)"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M8.5 3a5.5 5.5 0 014.383 8.823l4.147 4.147a.75.75 0 01-1.06 1.06l-4.147-4.147A5.5 5.5 0 118.5 3zm0 1.5a4 4 0 100 8 4 4 0 000-8z" fill="currentColor"/>
        </svg>
      </button>

      <span class="navbar-text hidden lg:block text-gray-700 dark:text-gray-300 text-sm text-right border-l-2 border-primary/20 pl-4 ml-4 pb-2 whitespace-nowrap">
        {siteConfig.description}
      </span>
      
      <button 
        class="navbar-toggler p-2 rounded border border-gray-300 dark:border-gray-600 min-h-[44px] min-w-[44px] md:hidden focus:outline-2 focus:outline-primary focus:outline-offset-2 ml-2" 
        type="button" 
        aria-controls="navbar" 
        aria-expanded="false" 
        aria-label="Toggle navigation"
      >
        <span class="navbar-toggler-icon block w-6 h-6 bg-no-repeat bg-center"></span>
      </button>
    </div>
  </div>
</nav>

<style>
  @reference "../styles/global.css";
  
  /* Touch feedback */
  .nav-link:active {
    @apply opacity-80;
  }
  
  /* Navbar toggler icon - light mode */
  .navbar-toggler-icon {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba%280, 0, 0, 0.55%29' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
  }
  
  /* Dark mode toggler icon */
  @media (prefers-color-scheme: dark) {
    .navbar-toggler-icon {
      background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba%28255, 255, 255, 0.75%29' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
    }
  }
  
  /* Toggler expanded state */
  .navbar-toggler[aria-expanded="true"] {
    @apply bg-primary/10 border-primary;
  }
  
  .navbar-toggler[aria-expanded="true"] .navbar-toggler-icon {
    @apply opacity-80;
  }
  
  .navbar-toggler:active {
    @apply bg-primary/15;
  }
  
  /* Mobile navigation enhancements */
  @media (max-width: 767px) {
    /* Separator between nav items */
    .nav-item:not(:last-child) {
      border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    }

    /* Expanded menu background separation */
    .nav-collapse.show {
      border-top: 1px solid rgba(0, 0, 0, 0.06);
      margin-top: 0.5rem;
      padding-top: 0.25rem;
    }

    /* Full-width nav links for larger tap targets */
    .nav-link {
      width: 100%;
    }
  }

  /* Dark mode variants for mobile */
  @media (max-width: 767px) and (prefers-color-scheme: dark) {
    .nav-item:not(:last-child) {
      border-bottom-color: rgba(255, 255, 255, 0.08);
    }

    .nav-collapse.show {
      border-top-color: rgba(255, 255, 255, 0.08);
    }
  }
</style>
