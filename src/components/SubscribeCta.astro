---
import Icon from './Icon.astro';
---

<div class="subscribe-cta group">
  <div class="flex items-center gap-3">
    <span class="subscribe-icon" aria-hidden="true">
      <Icon name="rss" />
    </span>
    <p class="text-sm text-gray-600 dark:text-gray-400 m-0">
      Enjoy this post? <a href="/feed.xml" class="subscribe-link">Subscribe via RSS</a> to get notified when new posts are published.
    </p>
  </div>
</div>

<style>
  @reference "../styles/global.css";

  .subscribe-cta {
    @apply flex items-center gap-4 px-4 py-3 rounded-lg;
    @apply border border-gray-200;
    @apply transition-all duration-200;
  }

  .subscribe-cta:hover {
    @apply border-primary/40 shadow-sm;
    background: color-mix(in srgb, var(--color-primary) 3%, transparent);
  }

  .subscribe-icon {
    @apply flex items-center justify-center w-9 h-9 rounded-full;
    @apply bg-primary/10 text-primary;
    @apply transition-colors duration-200;
    flex-shrink: 0;
  }

  .subscribe-cta:hover .subscribe-icon {
    @apply bg-primary/20;
  }

  .subscribe-link {
    @apply text-primary font-semibold no-underline;
    @apply transition-colors duration-200;
  }

  .subscribe-link:hover {
    @apply underline;
  }

  /* Dark mode adjustments */
  @media (prefers-color-scheme: dark) {
    .subscribe-cta {
      @apply border-gray-700;
    }

    .subscribe-cta:hover {
      @apply border-primary/30;
      background: color-mix(in srgb, var(--color-primary) 6%, transparent);
    }

    .subscribe-icon {
      @apply bg-primary/20 text-primary-300;
    }

    .subscribe-cta:hover .subscribe-icon {
      @apply bg-primary/30;
    }

    .subscribe-link {
      @apply text-primary-300;
    }
  }
</style>
