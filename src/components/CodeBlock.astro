---
/**
 * CodeBlock Component
 * 
 * Enhanced code block with title and copy functionality.
 * 
 * Usage in MDX:
 * <CodeBlock title="example.js" language="javascript">
 * const message = 'Hello, World!';
 * console.log(message);
 * </CodeBlock>
 */

interface Props {
  title?: string;
  language?: string;
}

const { title, language } = Astro.props;
---

<div class="not-prose border border-gray-200 dark:border-gray-700 rounded-lg my-4 overflow-hidden">
  {title && (
    <div class="flex justify-between items-center px-4 py-3 bg-gradient-to-r from-gray-50 to-gray-100/50 dark:from-gray-700/50 dark:to-gray-800/50 border-b border-gray-200 dark:border-gray-600">
      <span class="font-mono text-sm font-semibold text-gray-800 dark:text-gray-200">{title}</span>
      {language && (
        <span class="inline-flex items-center gap-1 text-xs text-gray-600 dark:text-gray-300 uppercase font-medium tracking-wide">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
          {language}
        </span>
      )}
    </div>
  )}
  <div class="p-0 code-block-content">
    <slot />
  </div>
</div>

<style>
  .code-block-content :global(pre) {
    margin: 0;
    border-radius: 0;
  }
</style>
