---
/**
 * CodeBlock Component
 * 
 * Enhanced code block with title and copy functionality.
 * 
 * Usage in MDX:
 * <CodeBlock title="example.js" language="javascript">
 * const message = 'Hello, World!';
 * console.log(message);
 * </CodeBlock>
 */

interface Props {
  title?: string;
  language?: string;
}

const { title, language } = Astro.props;
---

<div class="not-prose border border-gray-200 dark:border-gray-700 rounded my-4 overflow-hidden">
  {title && (
    <div class="flex justify-between items-center px-3 py-2 bg-gray-50 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
      <span class="font-mono text-sm font-semibold text-gray-800 dark:text-gray-200">{title}</span>
      {language && <span class="text-xs text-gray-600 dark:text-gray-300 uppercase">{language}</span>}
    </div>
  )}
  <div class="p-0 code-block-content">
    <slot />
  </div>
</div>

<style>
  .code-block-content :global(pre) {
    margin: 0;
    border-radius: 0;
  }
</style>
