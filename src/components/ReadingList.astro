---
/**
 * ReadingList component - Displays curated reading lists for blog posts
 *
 * Renders a "Further reading" section with numbered links from the post's
 * frontmatter `posts` and/or `roles` fields.
 *
 * Supports two data formats:
 * - Object/map: { "Title": "/url/" } — key as link text, value as href
 * - Array: ["/url/"] — derives a readable title from the URL slug
 */

interface Props {
  posts?: Record<string, string> | string[] | undefined;
  roles?: Record<string, string> | string[] | undefined;
}

const { posts, roles } = Astro.props;

/**
 * Convert a URL path to a readable title by extracting the slug portion,
 * replacing hyphens with spaces, and capitalizing each word.
 */
function slugToTitle(url: string): string {
  const segments = url.replace(/\/$/, '').split('/');
  const slug = segments[segments.length - 1] || url;
  return slug
    .replace(/-/g, ' ')
    .replace(/\b\w/g, (c) => c.toUpperCase());
}

/**
 * Normalize posts/roles data into an array of { title, url } objects.
 */
function normalizeEntries(
  data: Record<string, string> | string[],
): { title: string; url: string }[] {
  if (Array.isArray(data)) {
    return data.map((url) => ({ title: slugToTitle(url), url }));
  }
  return Object.entries(data).map(([title, url]) => ({ title, url }));
}

const postEntries = posts ? normalizeEntries(posts) : [];
const roleEntries = roles ? normalizeEntries(roles) : [];
const hasContent = postEntries.length > 0 || roleEntries.length > 0;
---

{hasContent && (
  <aside
    class="not-prose mt-8 rounded-lg border border-gray-200 bg-white p-5 dark:border-gray-700 dark:bg-gray-800"
    aria-label="Further reading"
  >
    {postEntries.length > 0 && (
      <div>
        <h2 class="mb-3 text-lg font-semibold text-gray-900 dark:text-gray-100">
          Further reading
        </h2>
        <ol class="list-decimal list-inside space-y-1.5 text-base text-gray-700 dark:text-gray-300">
          {postEntries.map(({ title, url }) => (
            <li>
              <a
                href={url}
                class="text-primary hover:text-primary-700 dark:text-primary-300 dark:hover:text-primary-200 underline decoration-primary/30 hover:decoration-primary transition-colors duration-200"
              >
                {title}
              </a>
            </li>
          ))}
        </ol>
      </div>
    )}

    {roleEntries.length > 0 && (
      <div
        class={postEntries.length > 0
          ? 'mt-5 border-t border-gray-200 pt-5 dark:border-gray-700'
          : ''}
      >
        <h2 class="mb-3 text-lg font-semibold text-gray-900 dark:text-gray-100">
          Related roles
        </h2>
        <ol class="list-decimal list-inside space-y-1.5 text-base text-gray-700 dark:text-gray-300">
          {roleEntries.map(({ title, url }) => (
            <li>
              <a
                href={url}
                class="text-primary hover:text-primary-700 dark:text-primary-300 dark:hover:text-primary-200 underline decoration-primary/30 hover:decoration-primary transition-colors duration-200"
              >
                {title}
              </a>
            </li>
          ))}
        </ol>
      </div>
    )}
  </aside>
)}
