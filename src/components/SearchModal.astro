---
/**
 * Search Modal Component
 *
 * Full-screen search overlay powered by Pagefind.
 * Opens via search button in Navigation or ⌘K / Ctrl+K keyboard shortcut.
 * Loads Pagefind JS and the modal's CSS only when search is first opened
 * (zero JS / no modal CSS shipped on the critical path by default).
 */
---

<div id="search-modal" class="search-modal" role="dialog" aria-modal="true" aria-label="Search" hidden>
  <div class="search-backdrop" data-search-close></div>
  <div class="search-container">
    <div class="search-header">
      <div class="search-input-wrapper">
        <svg class="search-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M8.5 3a5.5 5.5 0 014.383 8.823l4.147 4.147a.75.75 0 01-1.06 1.06l-4.147-4.147A5.5 5.5 0 118.5 3zm0 1.5a4 4 0 100 8 4 4 0 000-8z" fill="currentColor"/>
        </svg>
        <input
          id="search-input"
          type="search"
          placeholder="Search posts…"
          autocomplete="off"
          autofocus
          class="search-field"
          aria-label="Search posts"
        />
        <button type="button" class="search-close-btn" data-search-close aria-label="Close search">
          <kbd class="search-kbd" aria-hidden="true">Esc</kbd>
        </button>
      </div>
    </div>
    <div id="search-results" class="search-results" aria-live="polite"></div>
  </div>
</div>

<script>
  import '../scripts/search-modal.ts';
</script>

<!--
  Search modal styles are loaded lazily from src/styles/search-modal.css
  via a dynamic import in src/scripts/search-modal.ts the first time the
  modal is opened (or when search-result highlighting runs on a destination
  page). This keeps the modal's CSS off the critical path for the common
  case where the user never opens search.
-->
