---
/**
 * Footer Component
 * 
 * Site-wide footer with navigation links and social connections.
 * Uses Tailwind CSS utilities and minimal custom styles.
 * Matches the structure and styling of the Jekyll footer.
 * 
 * Uses inline SVG icons via the Icon component for better performance
 * (eliminates the ~77KB FontAwesome JS bundle).
 */

import { siteConfig, footerLinks, contactLinks } from '../config';
import Icon from './Icon.astro';
---

<footer class="mt-12 max-md:mt-8 pt-6 border-t-2 border-primary/10 dark:border-primary/20">
  <nav aria-label="Footer navigation">
    <div class="flex justify-between px-2 py-4 mb-6 flex-wrap max-md:justify-center max-md:flex-col max-md:items-center max-md:text-center max-md:gap-4">
      <ul class="contact-links flex flex-wrap list-none p-0 m-0 max-md:justify-center max-md:gap-1">
        {contactLinks.map((link) => (
          <li class="relative">
            <a 
              href={link.url} 
              aria-label={link.name}
              class="nav-link social-link text-gray-900 dark:text-gray-100 p-2 min-h-[44px] min-w-[44px] inline-flex items-center justify-center transition-all duration-200 hover:text-primary dark:hover:text-primary-400 touch-manipulation"
              target="_blank"
              rel="noopener noreferrer me"
            >
              <Icon name={link.icon} />
            </a>
          </li>
        ))}
      </ul>
      
      <ul class="flex flex-wrap list-none p-0 m-0 max-md:justify-center max-md:flex-wrap max-md:gap-0 max-md:border-t max-md:border-black/[0.06] max-md:pt-3 max-md:dark:border-white/[0.08]">
        {footerLinks.map((link) => (
          <li class="relative">
            <a href={link.url} class="nav-link link-secondary text-gray-700 dark:text-gray-300 hover:text-gray-800 dark:hover:text-gray-100 px-3 py-2 text-sm transition-all duration-200 footer-link">
              <Fragment set:html={link.title.replace(/&/g, '<span class="text-primary dark:text-primary-300 mx-0.5">&amp;</span>')} />
            </a>
          </li>
        ))}
        
        <li class="relative">
          <a href="/feed.xml" aria-label="RSS Feed" class="nav-link social-link text-gray-900 dark:text-gray-100 p-2 min-h-[44px] min-w-[44px] inline-flex items-center justify-center transition-all duration-200 hover:text-primary dark:hover:text-primary-400 touch-manipulation">
            <Icon name="rss" />
          </a>
        </li>
      </ul>
    </div>
  </nav>
  <div class="border-t border-gray-200 dark:border-gray-700 pt-4 pb-6 flex justify-between items-center text-xs text-gray-600 dark:text-gray-300 px-2">
    <span>© {new Date().getFullYear()} {siteConfig.author}</span>
    <a href="#content" class="text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-primary-400 transition-colors duration-200 inline-flex items-center gap-1">
      Back to top
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
      </svg>
    </a>
  </div>
</footer>

