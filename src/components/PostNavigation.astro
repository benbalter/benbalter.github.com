---
/**
 * Post Navigation Component
 * 
 * Displays previous and next post links for sequential blog navigation.
 */

interface Props {
  prevPost?: { title: string; url: string };
  nextPost?: { title: string; url: string };
}

const { prevPost, nextPost } = Astro.props;
---

{(prevPost || nextPost) && (
  <nav aria-label="Post navigation" class="mt-10 grid gap-4 md:grid-cols-2">
    {prevPost ? (
      <a href={prevPost.url} class="group flex flex-col p-5 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-primary dark:hover:border-primary/40 hover:shadow-md dark:hover:shadow-card-dark hover:-translate-y-px no-underline transition-all duration-200">
        <span class="text-xs font-medium uppercase tracking-wide text-gray-600 dark:text-gray-300 mb-1">← Older</span>
        <span class="text-sm font-semibold text-gray-900 dark:text-gray-100 group-hover:text-primary dark:group-hover:text-primary-300 transition-colors duration-200 line-clamp-2">{prevPost.title}</span>
      </a>
    ) : <div />}
    {nextPost && (
      <a href={nextPost.url} class="group flex flex-col p-5 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-primary dark:hover:border-primary/40 hover:shadow-md dark:hover:shadow-card-dark hover:-translate-y-px no-underline transition-all duration-200 md:text-right md:col-start-2">
        <span class="text-xs font-medium uppercase tracking-wide text-gray-600 dark:text-gray-300 mb-1">Newer →</span>
        <span class="text-sm font-semibold text-gray-900 dark:text-gray-100 group-hover:text-primary dark:group-hover:text-primary-300 transition-colors duration-200 line-clamp-2">{nextPost.title}</span>
      </a>
    )}
  </nav>
)}
