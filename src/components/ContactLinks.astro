---
/**
 * ContactLinks Component
 * 
 * Displays social media contact links with icons.
 * Used on About and Contact pages to avoid duplication.
 * Uses Tailwind CSS utility classes for maintainability.
 * 
 * Uses inline SVG icons via the Icon component for better performance.
 */

import { siteConfig, contactLinks } from '../config';
import Icon from './Icon.astro';
---

<div class="contact-links mt-8">
  <div class="grid grid-cols-2 md:grid-cols-5 gap-3 max-w-2xl mx-auto">
    {contactLinks.map((link) => (
      <a href={link.url} rel="me noopener" target="_blank" class="group flex flex-col items-center justify-center text-center p-4 rounded-lg bg-gray-50 dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700 hover:border-primary/30 dark:hover:border-primary/40 hover:shadow-card dark:hover:shadow-card-dark no-underline transition-all duration-200">
        <span class="mb-2 text-gray-600 dark:text-gray-300 group-hover:text-primary dark:group-hover:text-primary-300 transition-colors duration-200">
          <Icon name={link.icon} />
        </span>
        <span class="text-xs text-gray-600 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-gray-100 transition-colors duration-200">{link.name}</span>
      </a>
    ))}
  </div>

  <p class="text-sm mt-6 text-center">
    <a href="/key.asc">PGP: <code class="text-xs text-gray-700 dark:text-gray-300">{siteConfig.pgpKey}</code></a>
  </p>
</div>
