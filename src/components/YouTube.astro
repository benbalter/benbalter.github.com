---
/**
 * YouTube Component
 * 
 * Embed YouTube videos in blog posts with responsive sizing.
 * Uses Tailwind aspect-ratio utility for responsive 16:9 aspect ratio.
 * 
 * Usage in MDX:
 * <YouTube id="dQw4w9WgXcQ" title="Video Title" />
 */

interface Props {
  id: string;
  title?: string;
}

const { id, title = 'YouTube video' } = Astro.props;
const embedUrl = `https://www.youtube.com/embed/${id}`;
---

<div class="not-prose my-6 rounded-lg overflow-hidden border border-gray-200 dark:border-gray-700 shadow-sm">
  <div class="aspect-video">
    <iframe
      src={embedUrl}
      title={title}
      class="w-full h-full"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
      loading="lazy"
    ></iframe>
  </div>
</div>
