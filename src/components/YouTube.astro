---
/**
 * YouTube Component
 * 
 * Embed YouTube videos with a performance-optimized facade pattern.
 * Uses astro-embed's YouTube component which renders a static thumbnail
 * at build time and only loads the iframe when the user clicks play.
 * This eliminates the ~500KB iframe payload on initial page load.
 * 
 * Usage in MDX:
 * <YouTube id="dQw4w9WgXcQ" title="Video Title" />
 */

import { YouTube as AstroYouTube } from 'astro-embed';

interface Props {
  id: string;
  title?: string;
}

const { id, title = 'YouTube video' } = Astro.props;
---

<div class="not-prose my-6 rounded-lg overflow-hidden border border-gray-200 dark:border-gray-700 shadow-sm">
  <AstroYouTube id={id} title={title} />
</div>
