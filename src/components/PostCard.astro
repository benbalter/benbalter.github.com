---
/**
 * PostCard Component
 * 
 * Display a blog post with title, date, description, and reading time in a card format.
 * Uses Tailwind CSS best practices: utility-first with minimal custom CSS.
 * 
 * Props:
 * - title: Post title
 * - url: Post URL
 * - date: Post date (formatted string for display)
 * - isoDate: Post date in ISO 8601 format (YYYY-MM-DD) for datetime attribute
 * - description: Post description/excerpt
 * - readingTime: Reading time in minutes
 * - variant: 'default' for standard cards, 'featured' for prominent styling
 */

import { formatReadingTime } from '../utils/reading-time';
import { stripMarkdown } from '../utils/strip-markdown';

interface Props {
  title: string;
  url: string;
  date: string;
  isoDate: string;
  description?: string;
  readingTime: number;
  variant?: 'default' | 'featured';
}

const { title, url, date, isoDate, description, readingTime, variant = 'default' } = Astro.props;
const isFeatured = variant === 'featured';
---

<article class:list={[
  'group relative h-full rounded-lg border border-gray-200 bg-white transition-all duration-150 hover:border-primary dark:border-gray-700 dark:bg-gray-800',
  isFeatured
    ? 'border-t-2 border-t-primary/20 hover:border-t-primary/60 hover:shadow-lg hover:-translate-y-0.5'
    : 'max-md:rounded-md hover:shadow-md hover:-translate-y-px dark:hover:border-primary/40',
]}>
  <div class={isFeatured ? 'p-6 max-md:p-4 max-md:pt-3' : 'p-4 max-md:pt-3'}>
    <h3 class:list={[
      'leading-snug tracking-tight',
      isFeatured ? 'mb-4 text-xl font-bold' : 'mb-2 text-base font-semibold',
    ]}>
      <a href={url} class="text-gray-900 no-underline before:absolute before:inset-0 transition-colors duration-200 group-hover:text-primary dark:group-hover:text-primary-300 dark:text-gray-100">{title}</a>
    </h3>
    <div class:list={[
      'text-sm text-gray-600 dark:text-gray-300',
      isFeatured ? 'mb-4 max-md:mb-2' : 'mb-2',
    ]}>
      <time datetime={isoDate}>{date}</time>
      <span class={isFeatured ? 'mx-2' : 'mx-1'} aria-hidden="true">·</span>
      <span>{formatReadingTime(readingTime)}</span>
    </div>
    {description && (
      <p class:list={[
        'mb-0 leading-relaxed text-gray-700 dark:text-gray-300',
        isFeatured ? 'line-clamp-3' : 'line-clamp-2 text-sm',
      ]}>{stripMarkdown(description)}</p>
    )}
  </div>
</article>
