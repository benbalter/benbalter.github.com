---
/**
 * Blog Post Layout
 * 
 * Layout for rendering blog posts with proper metadata, structure, and styling.
 * Matches the Jekyll post layout with enhanced features.
 * Uses Tailwind CSS utility classes for maintainability.
 */

import BaseLayout from './BaseLayout.astro';
import Tldr from '../components/Tldr.astro';
import MiniBio from '../components/MiniBio.astro';
import Icon from '../components/Icon.astro';
import { siteConfig } from '../config';
import { calculateReadingTime, formatReadingTime } from '../utils/reading-time';
import { generateBlogPostingSchema, schemaToJsonLd } from '../utils/structured-data';
import { formatPostDate, getPostUrl } from '../utils/post-urls';
import ArchivedPostWarning from '../components/ArchivedPostWarning.astro';
import ShareButtons from '../components/ShareButtons.astro';
import PostNavigation from '../components/PostNavigation.astro';
import TableOfContents from '../components/TableOfContents.astro';
import CopyCodeButton from '../components/CopyCodeButton.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  title: string;
  description: string;
  pubDate?: Date;
  updatedDate?: Date;
  image?: string;
  author?: string;
  tags?: string[];
  relatedPosts?: CollectionEntry<'posts'>[];
  prevPost?: { title: string; url: string };
  nextPost?: { title: string; url: string };
  archived?: boolean;
  postId: string;
}

const { 
  title, 
  description, 
  pubDate, 
  updatedDate, 
  image,
  author = siteConfig.author,
  tags = [],
  relatedPosts = [],
  prevPost,
  nextPost,
  archived = false,
  postId,
} = Astro.props;

const formattedDate = pubDate ? formatPostDate(pubDate) : undefined;
const postUrl = new URL(Astro.url.pathname, siteConfig.url).toString();

// Calculate reading time using improved utility
const content = await Astro.slots.render('default');
const readingTime = calculateReadingTime(content);

// Generate BlogPosting structured data for blog posts
const blogPostingSchema = pubDate ? generateBlogPostingSchema({
  title,
  description,
  url: new URL(Astro.url.pathname, siteConfig.url).toString(),
  publishedTime: pubDate,
  modifiedTime: updatedDate,
  image,
  author,
}) : null;
---

<BaseLayout 
  title={title} 
  description={description}
  type="article"
  publishedTime={pubDate}
  modifiedTime={updatedDate}
  image={image}
  author={author}
>
  <div class="max-w-4xl mx-auto px-4">
    <div>
      <article>
        <header class="mb-8">
          <h1 class="text-3xl md:text-4xl font-bold leading-tight text-gray-900 dark:text-gray-100" transition:name="page-title">{title}</h1>
          
          {readingTime > 0 && (
            <div class="text-sm text-gray-600 dark:text-gray-300 mb-6">
              <span class="inline-flex items-center gap-1">
                <Icon name="clock" /> {readingTime} min read
              </span>
            </div>
          )}
          
          {description && (
            <Tldr description={description} />
          )}
        </header>
        
        {archived && <ArchivedPostWarning />}

        <TableOfContents content={content} />
        
        <div class="post-content entrybody prose prose-lg prose-primary max-w-none">
          <slot />
        </div>

        <CopyCodeButton />
        <ReadingProgress />
        
        {pubDate && (
          <div class="mt-8 border-t border-gray-200 dark:border-gray-700 py-4 flex flex-wrap items-center justify-between gap-x-3 gap-y-3 text-sm text-gray-600 dark:text-gray-300">
            <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
              <span>Originally published {formattedDate}</span>
              <span aria-hidden="true">·</span>
              <a class="text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-primary-300 transition-colors duration-200" href={`${siteConfig.githubRepoUrl}/commits/main/src/content/posts/${postId}`} target="_blank" rel="noopener noreferrer" aria-label="View revision history">View revision history</a>
            </div>
            <ShareButtons title={title} url={postUrl} />
          </div>
        )}
        
        {tags.length > 0 && (
          <div class="mt-4 mb-4">
            <div class="flex flex-wrap items-center gap-2">
              <span class="text-sm text-gray-600 dark:text-gray-300 font-medium uppercase tracking-wide">Tags</span>
              {tags.map((tag) => (
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary/10 dark:bg-primary/20 text-primary-700 dark:text-primary-300 border border-primary/20 dark:border-primary/30">{tag}</span>
              ))}
            </div>
          </div>
        )}
        
        {relatedPosts.length > 0 && (
          <section class="mt-6">
            <div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4 flex items-center gap-3">
                <span class="section-header-accent"></span>
                You might also enjoy
              </h3>
              <div class="grid gap-4 md:grid-cols-2">
                {relatedPosts.slice(0, 4).map((post) => {
                  const postReadingTime = calculateReadingTime(post.body);
                  return (
                    <article class="group relative p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-primary dark:hover:border-primary/40 hover:shadow-card dark:hover:shadow-card-dark transition-all duration-200">
                      <h4 class="text-base font-semibold mb-1 mt-0">
                        <a href={getPostUrl(post.id)} class="text-gray-900 dark:text-gray-100 no-underline group-hover:text-primary dark:group-hover:text-primary-300 transition-colors duration-200 before:absolute before:inset-0">{post.data.title}</a>
                      </h4>
                      <p class="text-sm text-gray-600 dark:text-gray-300 mb-0">{formatReadingTime(postReadingTime)}</p>
                    </article>
                  );
                })}
              </div>
            </div>
          </section>
        )}
        
        <PostNavigation prevPost={prevPost} nextPost={nextPost} />
        
        <footer class="border-t-2 border-gray-200 dark:border-gray-700 pt-6 mt-6 mb-8 post-footer">
          <div class="mini-bio-card mb-6">
            <MiniBio />
          </div>

          <a
            href={`${siteConfig.githubRepoUrl}/edit/main/src/content/posts/${postId}`}
            target="_blank"
            rel="noopener noreferrer"
            class="open-source-cta group"
          >
            <div class="flex items-center gap-3">
              <span class="open-source-icon" aria-hidden="true">
                <Icon name="pen-to-square" />
              </span>
              <div>
                <span class="block text-sm font-semibold text-gray-800 dark:text-gray-200 group-hover:text-primary dark:group-hover:text-primary-300 transition-colors duration-200">
                  This page is open source
                </span>
                <span class="block text-xs text-gray-600 dark:text-gray-300">
                  Help improve this article on GitHub
                </span>
              </div>
            </div>
            <span class="text-gray-500 dark:text-gray-400 group-hover:text-primary dark:group-hover:text-primary-300 transition-colors duration-200" aria-hidden="true">→</span>
          </a>
        </footer>
      </article>
      
      {blogPostingSchema && (
        <script type="application/ld+json" set:html={schemaToJsonLd(blogPostingSchema)} is:inline></script>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  @reference "../styles/global.css";
  
  /* Enhanced mini bio card styling */
  .mini-bio-card {
    @apply p-6 rounded-lg shadow-card;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-primary) 3%, transparent),
      color-mix(in srgb, var(--color-primary) 1%, transparent)
    );
    border-left: 3px solid var(--color-primary);
  }

  /* Open source edit CTA */
  .open-source-cta {
    @apply flex items-center justify-between gap-4 px-4 py-3 rounded-lg;
    @apply border border-gray-200 no-underline;
    @apply transition-all duration-200;
  }

  .open-source-cta:hover {
    @apply border-primary/40 shadow-sm;
    background: color-mix(in srgb, var(--color-primary) 3%, transparent);
  }

  .open-source-icon {
    @apply flex items-center justify-center w-9 h-9 rounded-full;
    @apply bg-primary/10 text-primary;
    @apply transition-colors duration-200;
    flex-shrink: 0;
  }

  .open-source-cta:hover .open-source-icon {
    @apply bg-primary/20;
  }
  
  /* Mobile adjustments */
  @media (max-width: 767px) {
    .mini-bio-card {
      @apply p-4;
    }
  }
  
  /* Dark mode adjustments */
  @media (prefers-color-scheme: dark) {
    .mini-bio-card {
      background: linear-gradient(
        135deg,
        color-mix(in srgb, var(--color-primary) 8%, transparent),
        color-mix(in srgb, var(--color-primary) 4%, transparent)
      );
      @apply shadow-card-dark;
    }

    .open-source-cta {
      @apply border-gray-700;
    }

    .open-source-cta:hover {
      @apply border-primary/30;
      background: color-mix(in srgb, var(--color-primary) 6%, transparent);
    }

    .open-source-icon {
      @apply bg-primary/20 text-primary-300;
    }

    .open-source-cta:hover .open-source-icon {
      @apply bg-primary/30;
    }
  }
</style>
