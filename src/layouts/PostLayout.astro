---
/**
 * Blog Post Layout
 * 
 * Layout for rendering blog posts with proper metadata, structure, and styling.
 * Matches the Jekyll post layout with enhanced features.
 * Uses Tailwind CSS utility classes for maintainability.
 */

import BaseLayout from './BaseLayout.astro';
import Tldr from '../components/Tldr.astro';
import MiniBio from '../components/MiniBio.astro';
import Icon from '../components/Icon.astro';
import { siteConfig } from '../config';
import { calculateReadingTime, formatReadingTime } from '../utils/reading-time';
import { generateBlogPostingSchema, schemaToJsonLd } from '../utils/structured-data';
import { formatPostDate, getPostUrl } from '../utils/post-urls';
import ArchivedPostWarning from '../components/ArchivedPostWarning.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  title: string;
  description: string;
  pubDate?: Date;
  updatedDate?: Date;
  image?: string;
  author?: string;
  tags?: string[];
  relatedPosts?: CollectionEntry<'posts'>[];
  archived?: boolean;
  postId: string;
}

const { 
  title, 
  description, 
  pubDate, 
  updatedDate, 
  image,
  author = siteConfig.author,
  tags = [],
  relatedPosts = [],
  archived = false,
  postId,
} = Astro.props;

const formattedDate = pubDate ? formatPostDate(pubDate) : undefined;

// Calculate reading time using improved utility
const content = await Astro.slots.render('default');
const readingTime = calculateReadingTime(content);

// Generate BlogPosting structured data for blog posts
const blogPostingSchema = pubDate ? generateBlogPostingSchema({
  title,
  description,
  url: new URL(Astro.url.pathname, siteConfig.url).toString(),
  publishedTime: pubDate,
  modifiedTime: updatedDate,
  image,
  author,
}) : null;
---

<BaseLayout 
  title={title} 
  description={description}
  type="article"
  publishedTime={pubDate}
  modifiedTime={updatedDate}
  image={image}
  author={author}
>
  <div class="row">
    <div class="col-md-10 offset-md-1 px-3">
      <article>
        <header class="mb-6">
          <h1 class="display-4 text-primary font-bold">{title}</h1>
          
          {description && (
            <Tldr description={description} />
          )}
          
          <div class="text-body-secondary text-sm mb-6">
            {readingTime > 0 && (
              <div class="inline-flex items-center gap-1">
                <Icon name="clock" /> {readingTime} min read
              </div>
            )}
          </div>
        </header>
        
        {archived && <ArchivedPostWarning />}
        
        <div class="post-content entrybody prose prose-lg prose-primary max-w-none dark:prose-invert">
          <slot />
        </div>
        
        {pubDate && (
          <div class="mt-8 border-t border-gray-200 dark:border-gray-700 py-4 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-gray-500 dark:text-gray-400">
            <span>Originally published {formattedDate}</span>
            <span aria-hidden="true">·</span>
            <a class="text-gray-500 dark:text-gray-400 hover:text-primary dark:hover:text-primary-300 transition-colors duration-200" href={`${siteConfig.githubRepoUrl}/commits/main/src/content/posts/${postId}`} target="_blank" rel="noopener noreferrer" aria-label="View revision history">View revision history</a>
          </div>
        )}
        
        {tags.length > 0 && (
          <div class="mt-4 mb-4">
            <div class="flex flex-wrap items-center gap-2">
              <span class="text-sm text-gray-500 dark:text-gray-400 font-medium uppercase tracking-wide">Tags</span>
              {tags.map((tag) => (
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary/10 dark:bg-primary/20 text-primary-700 dark:text-primary-300 border border-primary/20 dark:border-primary/30">{tag}</span>
              ))}
            </div>
          </div>
        )}
        
        {relatedPosts.length > 0 && (
          <section class="mt-6">
            <div>
              <h3 class="text-lg font-semibold text-body-emphasis mb-4 flex items-center gap-3">
                <span class="section-header-accent"></span>
                You might also enjoy
              </h3>
              <div class="grid gap-4 md:grid-cols-2">
                {relatedPosts.slice(0, 4).map((post) => {
                  const postReadingTime = calculateReadingTime(post.body);
                  return (
                    <article class="group relative p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-primary dark:hover:border-primary/40 hover:shadow-card dark:hover:shadow-card-dark transition-all duration-200">
                      <h4 class="text-base font-semibold mb-1 mt-0">
                        <a href={getPostUrl(post.slug)} class="text-gray-900 dark:text-gray-100 no-underline group-hover:text-primary dark:group-hover:text-primary-300 transition-colors duration-200 before:absolute before:inset-0">{post.data.title}</a>
                      </h4>
                      <p class="text-sm text-gray-500 dark:text-gray-400 mb-0">{formatReadingTime(postReadingTime)}</p>
                    </article>
                  );
                })}
              </div>
            </div>
          </section>
        )}
        
        <footer class="border-t-2 border-gray-200 dark:border-gray-700 pt-6 mt-6 mb-8 post-footer">
          <div class="row">
            <div class="col">
              <div class="mini-bio-card">
                <MiniBio />
              </div>
            </div>
            <div class="col-lg-4 text-center edit-section max-lg:mt-6">
              <p class="mb-2">
                <small>This page is open source. Please <a 
                  href={`${siteConfig.githubRepoUrl}/edit/main/src/content/posts/${postId}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  title="Help improve this article"
                  class="edit-link"
                >help improve it</a>.</small>
              </p>
              <a 
                class="btn btn-outline-primary btn-sm" 
                href={`${siteConfig.githubRepoUrl}/edit/main/src/content/posts/${postId}`}
                target="_blank"
                rel="noopener noreferrer"
                title="Help improve this article"
              >Edit</a>
            </div>
          </div>
        </footer>
      </article>
      
      {blogPostingSchema && (
        <script type="application/ld+json" set:html={schemaToJsonLd(blogPostingSchema)} is:inline></script>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  @reference "../styles/global.css";
  
  /* Enhanced mini bio card styling */
  .mini-bio-card {
    @apply p-6 rounded-lg shadow-card;
    background: linear-gradient(
      135deg,
      rgba(51, 122, 183, 0.03),
      rgba(51, 122, 183, 0.01)
    );
    border-left: 3px solid #337ab7;
  }
  
  /* Edit section layout */
  .edit-section {
    @apply flex flex-col justify-center items-center;
  }
  
  .edit-link {
    @apply text-primary no-underline;
    border-bottom: 1px dotted #337ab7;
    @apply transition-all duration-200;
  }
  
  .edit-link:hover {
    border-bottom-color: transparent;
  }
  
  /* Mobile adjustments */
  @media (max-width: 767px) {
    .mini-bio-card {
      @apply p-4;
    }
  }
  
  /* Dark mode adjustments */
  @media (prefers-color-scheme: dark) {
    .mini-bio-card {
      background: linear-gradient(
        135deg,
        rgba(51, 122, 183, 0.08),
        rgba(51, 122, 183, 0.04)
      );
      @apply shadow-card-dark;
    }
    
    .edit-link {
      @apply text-primary-300;
      border-bottom-color: #80b9e6;
    }
  }
</style>
