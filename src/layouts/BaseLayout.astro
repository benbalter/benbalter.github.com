---
/**
 * Base Layout
 * 
 * Core layout for all pages with comprehensive SEO, Open Graph, and Twitter Card support.
 * Includes site-wide navigation, footer, and metadata.
 */

import { SEO } from 'astro-seo';
import { Font } from 'astro:assets';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import SearchModal from '../components/SearchModal.astro';
import { siteConfig, socialLinks } from '../config';
import { generatePersonSchema, generateProfilePageSchema, generateWebSiteSchema, generateBreadcrumbSchema, schemaToGraphJsonLd } from '../utils/structured-data';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  keywords?: string[];
  noindex?: boolean;
  hero?: boolean;
  suppressPersonSchema?: boolean;
}

const { 
  title = siteConfig.name, 
  description = siteConfig.description,
  image,
  type = 'website',
  publishedTime,
  modifiedTime,
  author = siteConfig.author,
  keywords = siteConfig.keywords,
  noindex = false,
  hero = false,
  suppressPersonSchema = false,
} = Astro.props;

const fullTitle = title === siteConfig.name ? `${title} | ${siteConfig.description}` : `${title} | ${siteConfig.name}`;
// Normalize canonical URL: ensure trailing slash on non-root paths so Astro's
// trailingSlash="always" config is consistently reflected in <link rel="canonical">.
const rawPath = Astro.url.pathname || '/';
const canonicalPath = rawPath === '/' || rawPath.endsWith('/') || /\.[a-z0-9]+$/i.test(rawPath)
  ? rawPath
  : rawPath + '/';
const canonicalUrl = new URL(canonicalPath, siteConfig.url).toString();

// Default OG image if none provided
const ogImage = image 
  ? new URL(image, siteConfig.url).toString()
  : new URL('/assets/img/headshot.jpg', siteConfig.url).toString();

// Generate structured data (JSON-LD) for SEO
// Use ProfilePage on homepage (a Google-supported rich result type), Person elsewhere
const isHomepage = Astro.url.pathname === '/' || Astro.url.pathname === '';
const primarySchema = isHomepage 
  ? generateProfilePageSchema() 
  : (suppressPersonSchema ? null : generatePersonSchema());
const websiteSchema = generateWebSiteSchema();

// Generate breadcrumb schema based on URL path
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbItems: Array<{ name: string; url?: string }> = [
  { name: 'Home', url: siteConfig.url }
];

// Detect blog post URL pattern: /YYYY/MM/DD/slug/
const blogPostPattern = /^\/\d{4}\/\d{2}\/\d{2}\/.+/;
if (blogPostPattern.test(Astro.url.pathname)) {
  // For blog posts, skip meaningless date segments
  breadcrumbItems.push(
    { name: 'Posts', url: `${siteConfig.url}/posts/` },
    { name: title }
  );
} else {
  // Generic breadcrumbs for non-post pages
  let currentPath = siteConfig.url;
  pathSegments.forEach((segment, index) => {
    currentPath += `/${segment}`;
    const cleanedSegment = segment.replace(/\.[^/.]+$/, '').replace(/[-_]+/g, ' ');
    const name = cleanedSegment.split(' ').map(word =>
      word.length > 0 ? word.charAt(0).toUpperCase() + word.slice(1) : ''
    ).join(' ');
    const isLastItem = index === pathSegments.length - 1;
    breadcrumbItems.push({ 
      name, 
      url: isLastItem ? undefined : currentPath
    });
  });
}

const breadcrumbSchema = pathSegments.length > 0 ? generateBreadcrumbSchema(breadcrumbItems) : null;

// Combine all schemas
const schemas = [primarySchema, websiteSchema, breadcrumbSchema].filter(Boolean) as Array<typeof websiteSchema>;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- SEO Meta Tags (via astro-seo) -->
    <SEO
      title={fullTitle}
      description={description}
      canonical={canonicalUrl}
      noindex={noindex}
      nofollow={noindex}
      charset="UTF-8"
      openGraph={{
        basic: {
          title: fullTitle,
          type: type,
          image: ogImage,
          url: canonicalUrl,
        },
        optional: {
          description: description,
          locale: 'en_US',
          siteName: siteConfig.name,
        },
        image: {
          width: 1200,
          height: 630,
          alt: description,
        },
        ...(type === 'article' && publishedTime ? {
          article: {
            publishedTime: publishedTime.toISOString(),
            modifiedTime: modifiedTime?.toISOString(),
            authors: author ? [author] : undefined,
          }
        } : {}),
      }}
      twitter={{
        card: 'summary_large_image',
        site: siteConfig.twitterHandle,
        creator: siteConfig.twitterHandle,
        title: fullTitle,
        description: description,
        image: ogImage,
        imageAlt: description,
      }}
      extend={{
        meta: [
          // Compatibility and Viewport
          { name: 'viewport', content: 'width=device-width, initial-scale=1.0, shrink-to-fit=no, viewport-fit=cover' },
          // Generator and Author
          { name: 'generator', content: Astro.generator },
          { name: 'author', content: author },
          // Keywords
          ...(keywords.length > 0 ? [{ name: 'keywords', content: keywords.join(', ') }] : []),
          // Color Scheme and Theme
          { name: 'color-scheme', content: 'light dark' },
          { name: 'theme-color', content: '#111111', media: '(prefers-color-scheme: light)' },
          { name: 'theme-color', content: '#eeeeee', media: '(prefers-color-scheme: dark)' },
        ],
        link: [
          // Favicons
          { rel: 'icon', type: 'image/x-icon', href: '/favicon.ico' },
          { rel: 'apple-touch-icon', sizes: '180x180', href: '/apple-touch-icon.png' },
          { rel: 'icon', type: 'image/png', sizes: '32x32', href: '/favicon-32x32.png' },
          { rel: 'icon', type: 'image/png', sizes: '16x16', href: '/favicon-16x16.png' },
          { rel: 'manifest', href: '/site.webmanifest' },
          // Additional Meta
          { rel: 'author', type: 'text/plain', href: '/humans.txt' },
          // Social Links (rel=me for verification)
          ...socialLinks.map((link) => ({ rel: 'me', href: link.url })),
          // DNS prefetch for origins used on some pages (low cost when unused,
          // unlike preconnect which opens full TCP+TLS connections)
          { rel: 'dns-prefetch', href: 'https://images.amazon.com' },
          { rel: 'dns-prefetch', href: 'https://user-images.githubusercontent.com' },
          // RSS Feed
          { rel: 'alternate', type: 'application/rss+xml', title: `${siteConfig.name} - RSS Feed`, href: '/feed.xml' },
          // Hero image preload
          ...(hero ? [{ rel: 'preload', href: '/assets/img/header.jpg', as: 'image', fetchPriority: 'high' as const }] : []),
        ],
      }}
    />
    
    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={schemaToGraphJsonLd(schemas)} is:inline></script>
    
    <!-- Font optimization via Astro Fonts API (no preload: font-display optional
         means the browser skips fonts not available immediately, so preloading
         them would waste bandwidth competing with critical JS) -->
    <Font cssVariable="--font-inter" />
    <Font cssVariable="--font-lora" />
    
    <!-- Note: Title, favicons, meta tags, social links, resource hints, and RSS feed
         are all declared in the SEO component above. Do not duplicate them here. -->
  </head>
  <body class="mt-2 text-gray-900 bg-white dark:text-gray-100 dark:bg-gray-900">
    <!-- Skip to main content link for accessibility -->
    <a href="#content" class="skip-to-content visually-hidden-focusable">
      Skip to main content
    </a>
    
    <div class="container">
      {hero && <div class="hero-unit relative"></div>}
      
      <Navigation hero={hero} />
      
      <main id="content" role="main" class="content" tabindex="-1">
        <slot />
      </main>
      
      <Footer />
      <BackToTop />
      <SearchModal />
    </div>
    
    <!-- Minimal navigation toggle script -->
    <script>
      import '../scripts/navToggle';
    </script>
  </body>
</html>
<!-- Proudly Powered by Astro | Generated {new Date().toISOString()} -->
