---
/**
 * Page Layout
 * 
 * Layout for static pages (e.g., About, Contact, Resume).
 * Simpler than the PostLayout, focused on content presentation.
 * Uses Tailwind CSS utility classes for maintainability.
 */

import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  noindex?: boolean;
}

const { 
  title, 
  description, 
  image,
  noindex = false,
} = Astro.props;
---

<BaseLayout 
  title={title} 
  description={description}
  image={image}
  noindex={noindex}
>
  <div class="max-w-4xl mx-auto px-4">
    <div>
      <article data-pagefind-body>
        <header class="mb-6">
          <h1 class="text-3xl md:text-4xl font-bold leading-tight text-gray-900 dark:text-gray-100" transition:name="page-title">{title}</h1>
        </header>
        
        <div class="page-body prose prose-lg prose-primary max-w-none">
          <slot />
        </div>
      </article>
    </div>
  </div>
</BaseLayout>
