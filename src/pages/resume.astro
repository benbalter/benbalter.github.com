---
/**
 * Resume Page
 * 
 * Displays Ben Balter's professional experience, education, and certifications.
 * Uses Astro content collections for consistent markdown rendering.
 */

import PageLayout from '../layouts/PageLayout.astro';
import { getEntry, getCollection, render, type CollectionEntry } from 'astro:content';
import { formatResumeDate } from '../utils/post-urls';
import { generateResumeSchema, schemaToJsonLd } from '../utils/structured-data';

// Load resume page data
const resumePage = await getEntry('pages', 'resume');
if (!resumePage) {
  throw new Error('Resume page data not found');
}

const { title, description, degrees, certifications, skills, summary } = resumePage.data;

// Load resume positions from content collection
const allPositions = await getCollection('resume-positions');

// Sort by start_date (most recent first)
const sortedPositions = allPositions.sort((a: CollectionEntry<'resume-positions'>, b: CollectionEntry<'resume-positions'>) => {
  return new Date(b.data.start_date).getTime() - new Date(a.data.start_date).getTime();
});

// Group positions by employer to handle multiple roles at same company
interface GroupedPosition {
  employer: string;
  positions: Array<CollectionEntry<'resume-positions'> & { Content: any }>;
}

// Group all positions by employer, regardless of order
const employerGroups = new Map<string, Array<CollectionEntry<'resume-positions'> & { Content: any }>>();
for (const position of sortedPositions) {
  const { Content } = await render(position);
  const positionWithContent = { ...position, Content };
  
  if (!employerGroups.has(position.data.employer)) {
    employerGroups.set(position.data.employer, []);
  }
  employerGroups.get(position.data.employer)!.push(positionWithContent);
}

// Convert to array and sort positions within each employer by start_date (most recent first)
const groupedPositions: GroupedPosition[] = Array.from(employerGroups.entries()).map(([employer, positions]) => ({
  employer,
  positions: positions.sort((a, b) => new Date(b.data.start_date).getTime() - new Date(a.data.start_date).getTime()),
}));

// Generate resume structured data (JSON-LD)
const resumeSchema = generateResumeSchema({
  positions: sortedPositions.map((p: CollectionEntry<'resume-positions'>) => ({
    employer: p.data.employer,
    title: p.data.title,
    startDate: p.data.start_date,
    endDate: p.data.end_date,
  })),
  degrees,
  certifications,
});
---

<PageLayout title={title} description={description} suppressPersonSchema>
  <header class="print-header" aria-hidden="true">
    <p class="print-name">Ben Balter</p>
    <p class="print-contact">
      Washington, DC
      <span aria-hidden="true"> · </span>
      <a href="mailto:ben@balter.com">ben@balter.com</a>
      <span aria-hidden="true"> · </span>
      <a href="https://ben.balter.com">ben.balter.com</a>
      <span aria-hidden="true"> · </span>
      <a href="https://www.linkedin.com/in/benbalter/">linkedin.com/in/benbalter</a>
    </p>
  </header>

  {summary && (
    <section class="resume-section resume-summary">
      <p class="summary-text">{summary}</p>
      <p class="resume-aux">
        Also available on <a href="https://www.linkedin.com/in/benbalter/" target="_blank" rel="noopener noreferrer">LinkedIn</a>.
        Use your browser's print-to-PDF to save a copy.
      </p>
    </section>
  )}

  {skills && skills.length > 0 && (
    <section class="resume-section">
      <h2>Areas of focus</h2>
      <div class="skills-grid">
        {skills.map((group: { group: string; items: string[] }) => (
          <div class="skill-group">
            <h3 class="skill-group-name">{group.group}</h3>
            <ul class="skill-list">
              {group.items.map((item: string) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="resume-section">
    <h2>Experience</h2>
    
    {groupedPositions.map((group) => (
      <div class="employer-group">
        <h3 class="employer-name">{group.employer}</h3>
        
        {group.positions.map((position, index) => (
          <div class:list={["position", { "position-last": index === group.positions.length - 1 }]}>
            <div class="position-header">
              <h4 class="position-title">{position.data.title}</h4>
              <span class="date-badge">
                {formatResumeDate(position.data.start_date) ?? 'Unknown'}—{position.data.end_date ? (formatResumeDate(position.data.end_date) ?? 'Unknown') : 'Present'}
              </span>
            </div>
            
            <div class="position-content">
              <position.Content />
            </div>
          </div>
        ))}
      </div>
    ))}
  </section>
  
  {degrees && degrees.length > 0 && (
    <section class="resume-section">
      <h2>Education</h2>
      
      {degrees.map((degree: { school: string; degree: string; date: string }) => (
        <div class="education-item">
          <div class="education-header">
            <h3 class="school-name">{degree.school}</h3>
            <span class="date-badge">{formatResumeDate(degree.date) ?? 'Unknown'}</span>
          </div>
          <div class="degree-name">{degree.degree}</div>
        </div>
      ))}
    </section>
  )}
  
  {certifications && certifications.length > 0 && (() => {
    const professional = certifications.filter((c: { category?: string }) => (c.category ?? 'professional') === 'professional');
    const personal = certifications.filter((c: { category?: string }) => c.category === 'personal');
    const renderCert = (cert: { authority: string; name: string; url?: string; expired?: boolean }) => (
      <div class="certification-item">
        <div class="certification-header">
          <span class="certification-authority">{cert.authority}</span>
          <span class="certification-name">
            {cert.url ? (
              <a href={cert.url} target="_blank" rel="noopener noreferrer" aria-label={`View ${cert.name} credential`}>{cert.name}</a>
            ) : (
              cert.name
            )}
            {cert.expired && (
              <span class="cert-expired" title="No longer actively maintained" aria-label="Expired — no longer actively maintained">Expired</span>
            )}
          </span>
        </div>
      </div>
    );
    return (
      <section class="resume-section">
        <h2>Certifications</h2>
        {professional.length > 0 && (
          <>
            <h3 class="cert-group-heading">Professional</h3>
            {professional.map(renderCert)}
          </>
        )}
        {personal.length > 0 && (
          <>
            <h3 class="cert-group-heading">Personal interests</h3>
            {personal.map(renderCert)}
          </>
        )}
      </section>
    );
  })()}

  <script type="application/ld+json" set:html={schemaToJsonLd(resumeSchema)} is:inline></script>
</PageLayout>

<style>
  /* ============================================================
   * Resume Sections
   * ============================================================ */
  .resume-section {
    margin-bottom: 2.5rem;
  }

  .resume-summary {
    padding: 1rem 1.25rem;
    background-color: color-mix(in srgb, var(--tw-prose-links, var(--color-primary, #337ab7)) 5%, transparent);
    border-left: 3px solid var(--tw-prose-links, var(--color-primary, #337ab7));
    border-radius: 0 0.375rem 0.375rem 0;
  }

  /* Darken link color inside the tinted summary box to meet WCAG AA (4.5:1)
     on the ~#f5f8fb background — plain primary (#337ab7) is only 4.27:1. */
  .resume-summary a {
    color: var(--color-primary-600, #2a6493);
  }

  .summary-text {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .resume-aux {
    margin: 0.5rem 0 0;
    font-size: 0.85rem;
    color: var(--color-gray-700, #495057);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
    margin-top: 1rem;
  }

  .skill-group-name {
    margin: 0 0 0.4rem;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary-700, #204d6f);
  }

  .skill-list {
    margin: 0;
    padding-left: 1.1rem;
    font-size: 0.95rem;
  }

  .skill-list li {
    margin-bottom: 0.15rem;
  }

  .cert-group-heading {
    margin: 1.25rem 0 0.5rem;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary-700, #204d6f);
  }

  .cert-group-heading:first-child,
  .cert-group-heading:first-of-type {
    margin-top: 0.25rem;
  }

  @media (prefers-color-scheme: dark) {
    .skill-group-name,
    .cert-group-heading {
      color: var(--color-primary-200, #b3d4f0);
    }

    .resume-aux {
      color: var(--color-gray-400, #adb5bd);
    }
  }

  .resume-section h2 {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-bottom: 2px solid var(--tw-prose-links, var(--color-primary, #337ab7));
    padding-bottom: 0.5rem;
  }

  /* ============================================================
   * Employer Groups (Timeline)
   * ============================================================ */
  .employer-group {
    margin-bottom: 2rem;
    border-left: 3px solid color-mix(in srgb, var(--tw-prose-links, var(--color-primary, #337ab7)) 30%, transparent);
    padding-left: 1.5rem;
    position: relative;
  }

  .employer-name {
    margin-top: 0;
  }

  /* ============================================================
   * Position Entries
   * ============================================================ */
  .position {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--tw-prose-hr, #dee2e6);
    position: relative;
  }

  .position.position-last {
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 0;
  }

  /* Timeline dot */
  .position-header::before {
    content: '';
    position: absolute;
    left: -1.5rem;
    top: 0.45rem;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background-color: var(--tw-prose-links, var(--color-primary, #337ab7));
    transform: translateX(calc(-50% - 1.5px));
  }

  .position-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.5rem;
    position: relative;
  }

  .position-title {
    margin: 0;
    flex: 1;
  }

  .date-badge {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-primary-700, #204d6f);
    background-color: color-mix(in srgb, var(--tw-prose-links, var(--color-primary, #337ab7)) 8%, transparent);
    padding: 0.15rem 0.6rem;
    border-radius: 9999px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ============================================================
   * Position Content
   * ============================================================ */
  .position-content :global(p) {
    margin-bottom: 0.5rem;
  }

  .position-content :global(ul) {
    margin-top: 0.25rem;
  }

  /* ============================================================
   * Education
   * ============================================================ */
  .education-item {
    padding-bottom: 1rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--tw-prose-hr, #dee2e6);
  }

  .education-item:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .education-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .school-name {
    margin: 0;
  }

  .degree-name {
    margin-top: 0.15rem;
  }

  /* ============================================================
   * Certifications
   * ============================================================ */
  .certification-item {
    padding-bottom: 0.75rem;
    margin-bottom: 0.75rem;
    border-bottom: 1px solid var(--tw-prose-hr, #dee2e6);
  }

  .certification-item:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .certification-header {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .certification-authority {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .cert-expired {
    display: inline-block;
    margin-left: 0.5rem;
    padding: 0.05rem 0.5rem;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gray-700, #495057);
    background-color: color-mix(in srgb, var(--color-gray-600, #6c757d) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-gray-600, #6c757d) 25%, transparent);
    border-radius: 9999px;
    vertical-align: middle;
    white-space: nowrap;
  }

  .certification-name a[href] + .cert-expired,
  .certification-name > .cert-expired {
    text-decoration: none;
  }

  @media (prefers-color-scheme: dark) {
    .cert-expired {
      color: var(--color-gray-400, #adb5bd);
      background-color: color-mix(in srgb, var(--color-gray-400, #adb5bd) 12%, transparent);
      border-color: color-mix(in srgb, var(--color-gray-400, #adb5bd) 30%, transparent);
    }
  }

  @media print {
    .cert-expired {
      background-color: transparent;
      border-color: #999;
      color: #555;
    }
  }

  /* ============================================================
   * Dark Mode
   * ============================================================ */
  @media (prefers-color-scheme: dark) {
    .date-badge {
      color: var(--color-primary-200, #b3d4f0);
      background-color: color-mix(in srgb, var(--tw-prose-links, #80b9e6) 15%, transparent);
    }
  }

  /* ============================================================
   * Mobile Responsive
   * ============================================================ */
  @media (max-width: 768px) {
    .position-header {
      flex-direction: column;
      gap: 0.25rem;
    }

    .position-header .date-badge {
      align-self: flex-start;
    }

    .education-header {
      flex-direction: column;
      gap: 0.25rem;
    }

    .education-header .date-badge {
      align-self: flex-start;
    }

    .employer-group {
      padding-left: 1rem;
    }

    .position-header::before {
      left: -1rem;
      transform: translateX(calc(-50% - 1.5px));
    }
  }

  /* ============================================================
   * Print-only header (hidden on screen)
   * ============================================================ */
  .print-header {
    display: none;
  }

  /* ============================================================
   * Print
   * ============================================================ */
  @media print {
    @page {
      margin: 0.6in 0.65in;
    }

    /* Show the print-only header with name + contact strip */
    .print-header {
      display: block;
      margin: 0 0 1rem;
      padding-bottom: 0.75rem;
      border-bottom: 2px solid #000;
    }

    .print-name {
      margin: 0 0 0.25rem;
      font-size: 22pt;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: #000;
    }

    .print-contact {
      margin: 0;
      font-size: 9.5pt;
      color: #333;
    }

    .print-contact a {
      color: #333;
      text-decoration: none;
    }

    /* Hide the onscreen "Resume" page H1 — redundant with the name block */
    :global(article > header),
    :global(article > header h1) {
      display: none !important;
    }

    /* Hide the "also on LinkedIn / print to PDF" helper — already printing */
    .resume-aux {
      display: none !important;
    }

    /* Tighter summary card in print */
    .resume-summary {
      background-color: transparent !important;
      border-left: none !important;
      padding: 0 !important;
      margin-bottom: 0.75rem;
    }

    .summary-text {
      font-size: 10.5pt;
      font-style: italic;
    }

    /* Density: smaller base, tighter margins */
    .resume-section {
      margin-bottom: 1rem;
    }

    .resume-section h2 {
      font-size: 11pt;
      margin-top: 0.75rem;
      margin-bottom: 0.4rem;
      padding-bottom: 0.2rem;
      border-bottom-color: #000;
    }

    .employer-group {
      border-left: 1px solid #bbb;
      padding-left: 1rem;
      margin-bottom: 0.75rem;
      page-break-inside: avoid;
    }

    .employer-name {
      font-size: 12pt;
      margin-top: 0;
      margin-bottom: 0.35rem;
    }

    .position {
      margin-bottom: 0.6rem;
      padding-bottom: 0.5rem;
      page-break-inside: avoid;
      border-bottom-color: #eee;
    }

    .position-title {
      font-size: 10.5pt;
      font-weight: 600;
    }

    .position-header::before {
      width: 6px;
      height: 6px;
      background-color: #333;
      top: 0.4rem;
    }

    .date-badge {
      background-color: transparent !important;
      color: #333 !important;
      padding: 0 !important;
      font-size: 9pt;
      font-style: italic;
    }

    .position-content {
      font-size: 10pt;
    }

    .position-content :global(ul) {
      padding-left: 1.1rem;
    }

    .position-content :global(li) {
      margin-bottom: 0.15rem;
    }

    .skills-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
      margin-top: 0.4rem;
    }

    .skill-group-name {
      font-size: 9.5pt;
      color: #000;
      margin-bottom: 0.2rem;
    }

    .skill-list {
      font-size: 9.5pt;
    }

    .skill-list li {
      margin-bottom: 0;
    }

    .education-item,
    .certification-item {
      margin-bottom: 0.4rem;
      padding-bottom: 0.35rem;
      border-bottom-color: #eee;
      page-break-inside: avoid;
    }

    .school-name {
      font-size: 11pt;
    }

    .cert-group-heading {
      font-size: 9.5pt;
      color: #000;
      margin-top: 0.5rem;
      margin-bottom: 0.25rem;
    }

    .certification-authority {
      font-size: 8.5pt;
    }

    .certification-name {
      font-size: 10pt;
    }

    /* Don't suffix cert/LinkedIn links with their long URLs in print */
    .certification-name a::after,
    .print-contact a::after {
      content: none !important;
    }
  }
</style>
