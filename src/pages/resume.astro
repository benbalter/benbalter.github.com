---
/**
 * Resume Page
 * 
 * Displays Ben Balter's professional experience, education, and certifications.
 * Uses Astro content collections for consistent markdown rendering.
 */

import PageLayout from '../layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import { getEntry, type CollectionEntry } from 'astro:content';
import { formatResumeDate } from '../utils/post-urls';
import { getPublishedPosts } from '../utils/posts';
import { resolvePopularPosts } from '../utils/resume-writing';
import { getResumePositions } from '../utils/resume-data';
import { generateResumeSchema, schemaToJsonLd } from '../utils/structured-data';
import bookCover from '../../assets/img/open-and-async-cover-left.webp';

// The Open & Async position shows the book's cover inline (see loop below).
const BOOK_POSITION_ID = 'owner';

// Load resume page data
const resumePage = await getEntry('pages', 'resume');
if (!resumePage) {
  throw new Error('Resume page data not found');
}

const { title, description, robots, degrees, certifications, skills, summary } = resumePage.data;

// Selected writing mirrors the homepage's curated "Popular Posts" list.
const writing = resolvePopularPosts(await getPublishedPosts());

// Load positions (sorted + grouped by employer, pre-rendered) from the shared
// util so the web resume and the /resume-print PDF source can't drift.
const { sorted: sortedPositions, grouped: groupedPositions } = await getResumePositions();

// Generate resume structured data (JSON-LD)
const resumeSchema = generateResumeSchema({
  positions: sortedPositions.map((p: CollectionEntry<'resume-positions'>) => ({
    employer: p.data.employer,
    title: p.data.title,
    startDate: p.data.start_date,
    endDate: p.data.end_date,
  })),
  degrees,
  certifications,
});
---

<PageLayout title={title} description={description} robots={robots} suppressPersonSchema>
  <header class="print-header" aria-hidden="true">
    <p class="print-name">Ben Balter</p>
    <p class="print-contact">
      Washington, DC
      <span aria-hidden="true"> · </span>
      <a href="mailto:ben@balter.com">ben@balter.com</a>
      <span aria-hidden="true"> · </span>
      <a href="https://ben.balter.com">ben.balter.com</a>
      <span aria-hidden="true"> · </span>
      <a href="https://github.com/benbalter">github.com/benbalter</a>
      <span aria-hidden="true"> · </span>
      <a href="https://www.linkedin.com/in/benbalter/">linkedin.com/in/benbalter</a>
    </p>
  </header>

  {summary && (
    <section class="resume-section resume-summary">
      <p class="summary-text">{summary}</p>
      <p class="resume-contact">
        Washington, DC
        <span aria-hidden="true"> · </span>
        <a href="mailto:ben@balter.com">ben@balter.com</a>
      </p>
      <p class="resume-aux">
        Also available on <a href="https://www.linkedin.com/in/benbalter/" target="_blank" rel="me noopener noreferrer">LinkedIn</a> and <a href="https://github.com/benbalter" target="_blank" rel="me noopener noreferrer">GitHub</a>.
        Download as <a href="/resume.pdf" download="ben-balter-resume.pdf">PDF</a>, <a href="/resume.docx" download="ben-balter-resume.docx">Word</a>, or <a href="/resume.md" download="ben-balter-resume.md">Markdown</a>.
      </p>
    </section>
  )}

  {skills && skills.length > 0 && (
    <section class="resume-section">
      <h2>Areas of focus</h2>
      <div class="skills-grid">
        {skills.map((group: { group: string; items: string[] }) => (
          <div class="skill-group">
            <h3 class="skill-group-name">{group.group}</h3>
            <ul class="skill-list">
              {group.items.map((item: string) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="resume-section">
    <h2>Experience</h2>
    
    {groupedPositions.map((group) => (
      <div class="employer-group">
        <h3 class="employer-name">{group.employer}</h3>
        
        {group.positions.map((position, index) => (
          <div class:list={["position", { "position-last": index === group.positions.length - 1 }]}>
            <div class="position-header">
              <h4 class="position-title">{position.data.title}</h4>
              <span class="date-badge">
                {formatResumeDate(position.data.start_date) ?? 'Unknown'}—{position.data.end_date ? (formatResumeDate(position.data.end_date) ?? 'Unknown') : 'Present'}
              </span>
            </div>
            
            <div class:list={["position-content", { "position-content-with-cover": position.id === BOOK_POSITION_ID }]}>
              {position.id === BOOK_POSITION_ID && (
                <Image
                  src={bookCover}
                  alt="Open & Async book cover"
                  width={120}
                  height={147}
                  densities={[1, 2]}
                  loading="lazy"
                  decoding="async"
                  class="position-cover"
                />
              )}
              <position.Content />
            </div>
          </div>
        ))}
      </div>
    ))}
  </section>
  
  {writing && writing.length > 0 && (
    <section class="resume-section">
      <h2>Selected writing</h2>
      <ul class="writing-list" data-link-previews>
        {writing.map((item) => (
          <li class="writing-item">
            <a href={item.path}>{item.title}</a>
            <span class="writing-year">{item.year}</span>
          </li>
        ))}
      </ul>
    </section>
  )}

  {degrees && degrees.length > 0 && (
    <section class="resume-section">
      <h2>Education</h2>
      
      {degrees.map((degree: { school: string; degree: string; date: string }) => (
        <div class="education-item">
          <div class="education-header">
            <h3 class="school-name">{degree.school}</h3>
            <span class="date-badge">{formatResumeDate(degree.date) ?? 'Unknown'}</span>
          </div>
          <div class="degree-name">{degree.degree}</div>
        </div>
      ))}
    </section>
  )}
  
  {certifications && certifications.length > 0 && (() => {
    const professional = certifications.filter((c: { category?: string }) => (c.category ?? 'professional') === 'professional');
    const personal = certifications.filter((c: { category?: string }) => c.category === 'personal');
    const renderCert = (cert: { authority: string; name: string; url?: string; expired?: boolean }) => (
      <div class="certification-item">
        <div class="certification-header">
          <span class="certification-authority">{cert.authority}</span>
          <span class="certification-name">
            {cert.url ? (
              <a href={cert.url} target="_blank" rel="noopener noreferrer" aria-label={`View ${cert.name} credential`}>{cert.name}</a>
            ) : (
              cert.name
            )}
            {cert.expired && (
              <span class="cert-expired" title="No longer actively maintained" aria-label="Expired — no longer actively maintained">Expired</span>
            )}
          </span>
        </div>
      </div>
    );
    return (
      <section class="resume-section">
        <h2>Certifications</h2>
        {professional.length > 0 && (
          <>
            <h3 class="cert-group-heading">Professional</h3>
            {professional.map(renderCert)}
          </>
        )}
        {personal.length > 0 && (
          <>
            <h3 class="cert-group-heading">Personal interests</h3>
            {personal.map(renderCert)}
          </>
        )}
      </section>
    );
  })()}

  <script type="application/ld+json" set:html={schemaToJsonLd(resumeSchema)} is:inline></script>

  <!-- Hover preview cards for internal post links (Selected writing) -->
  <script>
    import '../scripts/link-previews';
  </script>
</PageLayout>

<style>
  /* ============================================================
   * Resume Sections
   * ============================================================ */
  .resume-section {
    margin-bottom: 2.5rem;
  }

  .resume-summary {
    padding: 1rem 1.25rem;
    background-color: color-mix(in srgb, var(--tw-prose-links, var(--color-primary, #337ab7)) 5%, transparent);
    border-left: 3px solid var(--tw-prose-links, var(--color-primary, #337ab7));
    border-radius: 0 0.375rem 0.375rem 0;
  }

  /* Darken link color inside the tinted summary box to meet WCAG AA (4.5:1)
     on the ~#f5f8fb background — plain primary (#337ab7) is only 4.27:1. */
  .resume-summary a {
    color: var(--color-primary-600, #2a6493);
  }

  /* In dark mode the summary box sits on a dark background, so the light-mode
     darkening flips to a contrast failure — lighten the links instead (matches
     the skill/cert dark-mode accent). */
  @media (prefers-color-scheme: dark) {
    .resume-summary a {
      color: var(--color-primary-200, #b3d4f0);
    }
  }

  .summary-text {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .resume-contact {
    margin: 0.6rem 0 0;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-gray-700, #495057);
  }

  .resume-aux {
    margin: 0.5rem 0 0;
    font-size: 0.85rem;
    color: var(--color-gray-700, #495057);
  }

  /* Book cover floated inline within the Open & Async position (web only —
     hidden in print, see @media print below). */
  .position-cover {
    float: right;
    width: 100px;
    height: auto;
    margin: 0 0 0.75rem 1.25rem;
    filter: drop-shadow(0 6px 12px rgb(0 0 0 / 0.18));
  }

  @media (max-width: 768px) {
    .position-cover {
      width: 80px;
      margin-left: 1rem;
    }
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
    margin-top: 1rem;
  }

  .skill-group-name {
    margin: 0 0 0.4rem;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary-700, #204d6f);
  }

  .skill-list {
    margin: 0;
    padding-left: 1.1rem;
    font-size: 0.95rem;
  }

  .skill-list li {
    margin-bottom: 0.15rem;
  }

  .cert-group-heading {
    margin: 1.25rem 0 0.5rem;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary-700, #204d6f);
  }

  .cert-group-heading:first-child,
  .cert-group-heading:first-of-type {
    margin-top: 0.25rem;
  }

  @media (prefers-color-scheme: dark) {
    .skill-group-name,
    .cert-group-heading {
      color: var(--color-primary-200, #b3d4f0);
    }

    .resume-aux,
    .resume-contact {
      color: var(--color-gray-400, #adb5bd);
    }
  }

  .resume-section h2 {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-bottom: 2px solid var(--tw-prose-links, var(--color-primary, #337ab7));
    padding-bottom: 0.5rem;
  }

  /* ============================================================
   * Employer Groups (Timeline)
   * ============================================================ */
  .employer-group {
    margin-bottom: 2rem;
    border-left: 3px solid color-mix(in srgb, var(--tw-prose-links, var(--color-primary, #337ab7)) 30%, transparent);
    padding-left: 1.5rem;
    position: relative;
  }

  .employer-name {
    margin-top: 0;
  }

  /* ============================================================
   * Position Entries
   * ============================================================ */
  .position {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--tw-prose-hr, #dee2e6);
    position: relative;
  }

  .position.position-last {
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 0;
  }

  /* Timeline dot */
  .position-header::before {
    content: '';
    position: absolute;
    left: -1.5rem;
    top: 0.45rem;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background-color: var(--tw-prose-links, var(--color-primary, #337ab7));
    transform: translateX(calc(-50% - 1.5px));
  }

  .position-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.5rem;
    position: relative;
  }

  .position-title {
    margin: 0;
    flex: 1;
  }

  .date-badge {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-primary-700, #204d6f);
    background-color: color-mix(in srgb, var(--tw-prose-links, var(--color-primary, #337ab7)) 8%, transparent);
    padding: 0.15rem 0.6rem;
    border-radius: 9999px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ============================================================
   * Position Content
   * ============================================================ */
  .position-content :global(p) {
    margin-bottom: 0.5rem;
  }

  .position-content :global(ul) {
    margin-top: 0.25rem;
  }

  /* ============================================================
   * Education
   * ============================================================ */
  .education-item {
    padding-bottom: 1rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--tw-prose-hr, #dee2e6);
  }

  .education-item:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .education-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .school-name {
    margin: 0;
  }

  .degree-name {
    margin-top: 0.15rem;
  }

  /* ============================================================
   * Selected Writing
   * ============================================================ */
  .writing-list {
    list-style: none;
    margin: 0.75rem 0 0;
    padding: 0;
  }

  /* Match the page's date treatment: title left, year right-aligned in a column
     (like Experience/Education), rather than a bullet with the year trailing. */
  .writing-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.55rem;
    line-height: 1.5;
  }

  .writing-item:last-child {
    margin-bottom: 0;
  }

  .writing-year {
    flex-shrink: 0;
    font-size: 0.8rem;
    font-variant-numeric: tabular-nums;
    color: var(--color-gray-700, #495057);
  }

  @media (prefers-color-scheme: dark) {
    .writing-year {
      color: var(--color-gray-400, #adb5bd);
    }
  }

  @media print {
    .writing-list {
      margin-top: 0.4rem;
      font-size: 10pt;
    }

    .writing-item {
      margin-bottom: 0.15rem;
      page-break-inside: avoid;
    }

    .writing-year {
      color: #555;
      font-style: italic;
    }

    /* Don't suffix writing links with their long URLs in print */
    .writing-item a::after {
      content: none !important;
    }
  }

  /* ============================================================
   * Certifications
   * ============================================================ */
  .certification-item {
    padding-bottom: 0.75rem;
    margin-bottom: 0.75rem;
    border-bottom: 1px solid var(--tw-prose-hr, #dee2e6);
  }

  .certification-item:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .certification-header {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .certification-authority {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .cert-expired {
    display: inline-block;
    margin-left: 0.5rem;
    padding: 0.05rem 0.5rem;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gray-700, #495057);
    background-color: color-mix(in srgb, var(--color-gray-600, #6c757d) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-gray-600, #6c757d) 25%, transparent);
    border-radius: 9999px;
    vertical-align: middle;
    white-space: nowrap;
  }

  .certification-name a[href] + .cert-expired,
  .certification-name > .cert-expired {
    text-decoration: none;
  }

  @media (prefers-color-scheme: dark) {
    .cert-expired {
      color: var(--color-gray-400, #adb5bd);
      background-color: color-mix(in srgb, var(--color-gray-400, #adb5bd) 12%, transparent);
      border-color: color-mix(in srgb, var(--color-gray-400, #adb5bd) 30%, transparent);
    }
  }

  @media print {
    .cert-expired {
      background-color: transparent;
      border-color: #999;
      color: #555;
    }
  }

  /* ============================================================
   * Dark Mode
   * ============================================================ */
  @media (prefers-color-scheme: dark) {
    .date-badge {
      color: var(--color-primary-200, #b3d4f0);
      background-color: color-mix(in srgb, var(--tw-prose-links, #80b9e6) 15%, transparent);
    }
  }

  /* ============================================================
   * Mobile Responsive
   * ============================================================ */
  @media (max-width: 768px) {
    .position-header {
      flex-direction: column;
      gap: 0.25rem;
    }

    .position-header .date-badge {
      align-self: flex-start;
    }

    .education-header {
      flex-direction: column;
      gap: 0.25rem;
    }

    .education-header .date-badge {
      align-self: flex-start;
    }

    .employer-group {
      padding-left: 1rem;
    }

    .position-header::before {
      left: -1rem;
      transform: translateX(calc(-50% - 1.5px));
    }
  }

  /* ============================================================
   * Print-only header (hidden on screen)
   * ============================================================ */
  .print-header {
    display: none;
  }

  /* ============================================================
   * Print
   * ============================================================ */
  @media print {
    @page {
      margin: 0.6in 0.65in;
    }

    /* Show the print-only header with name + contact strip */
    .print-header {
      display: block;
      margin: 0 0 1rem;
      padding-bottom: 0.75rem;
      border-bottom: 2px solid #000;
    }

    .print-name {
      margin: 0 0 0.25rem;
      font-size: 22pt;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: #000;
    }

    /* Keep the whole contact strip on one line; shrink to fit. */
    .print-contact {
      margin: 0;
      font-size: 8pt;
      color: #333;
      white-space: nowrap;
    }

    .print-contact a {
      color: #337ab7;
      text-decoration: none;
    }

    /* Hide the onscreen "Resume" page H1 — redundant with the name block */
    :global(article > header),
    :global(article > header h1) {
      display: none !important;
    }

    /* Hide the on-screen contact + helper lines — the print-header carries
       name and contact when printing. */
    .resume-aux,
    .resume-contact {
      display: none !important;
    }

    /* The inline book cover is a web-only visual — never in the printed PDF. */
    .position-cover {
      display: none !important;
    }

    /* Tighter summary card in print */
    .resume-summary {
      background-color: transparent !important;
      border-left: none !important;
      padding: 0 !important;
      margin-bottom: 0.75rem;
    }

    .summary-text {
      font-size: 10.5pt;
      font-style: italic;
    }

    /* Density: smaller base, tighter margins */
    .resume-section {
      margin-bottom: 1rem;
    }

    .resume-section h2 {
      font-size: 11pt;
      margin-top: 0.75rem;
      margin-bottom: 0.4rem;
      padding-bottom: 0.2rem;
      border-bottom-color: #000;
    }

    .employer-group {
      border-left: 1px solid #bbb;
      padding-left: 1rem;
      margin-bottom: 0.75rem;
      page-break-inside: avoid;
    }

    .employer-name {
      font-size: 12pt;
      margin-top: 0;
      margin-bottom: 0.35rem;
    }

    .position {
      margin-bottom: 0.6rem;
      padding-bottom: 0.5rem;
      page-break-inside: avoid;
      border-bottom-color: #eee;
    }

    .position-title {
      font-size: 10.5pt;
      font-weight: 600;
    }

    .position-header::before {
      width: 6px;
      height: 6px;
      background-color: #333;
      top: 0.4rem;
    }

    .date-badge {
      background-color: transparent !important;
      color: #333 !important;
      padding: 0 !important;
      font-size: 9pt;
      font-style: italic;
    }

    .position-content {
      font-size: 10pt;
    }

    .position-content :global(ul) {
      padding-left: 1.1rem;
    }

    .position-content :global(li) {
      margin-bottom: 0.15rem;
    }

    .skills-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
      margin-top: 0.4rem;
    }

    .skill-group-name {
      font-size: 9.5pt;
      color: #000;
      margin-bottom: 0.2rem;
    }

    .skill-list {
      font-size: 9.5pt;
    }

    .skill-list li {
      margin-bottom: 0;
    }

    .education-item,
    .certification-item {
      margin-bottom: 0.4rem;
      padding-bottom: 0.35rem;
      border-bottom-color: #eee;
      page-break-inside: avoid;
    }

    .school-name {
      font-size: 11pt;
    }

    .cert-group-heading {
      font-size: 9.5pt;
      color: #000;
      margin-top: 0.5rem;
      margin-bottom: 0.25rem;
    }

    .certification-authority {
      font-size: 8.5pt;
    }

    .certification-name {
      font-size: 10pt;
    }

    /* Digital-first PDF: the resume is read on screen, not paper. Keep content
       links blue and clickable, and never append the raw URL in parentheses
       (the global print stylesheet does that for printed articles). */
    .position-content :global(a),
    .certification-name a,
    .writing-list a {
      color: #337ab7;
      text-decoration: underline;
    }

    .position-content :global(a)::after,
    .certification-name a::after,
    .writing-list a::after,
    .print-contact a::after {
      content: none !important;
    }
  }
</style>
