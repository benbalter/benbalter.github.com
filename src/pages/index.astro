---
import BaseLayout from '../layouts/BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import { popularPostSlugs } from '../config';
import { getPublishedPosts } from '../utils/posts';
import { getPostMetadata } from '../utils/post-metadata';
import PostCard from '../components/PostCard.astro';
import BookCta from '../components/BookCta.astro';
import SubscribeCta from '../components/SubscribeCta.astro';
import { aboutContent, getFirstSentence } from '../content/about-bio';

const description = getFirstSentence(aboutContent);

// Get all published posts (excluding archived), sorted by date (newest first)
const allPosts = await getPublishedPosts();

// Sort posts by id (which contains date in Jekyll format YYYY-MM-DD)
const posts: CollectionEntry<'posts'>[] = allPosts.sort((a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) => 
  b.id.localeCompare(a.id)
);

// Split into featured (top 3) and regular posts
const featuredPosts = posts.slice(0, 3);
const regularPosts = posts.slice(3);

// Get popular posts based on configured slugs
const postsBySlug = new Map(allPosts.map((p: CollectionEntry<'posts'>) => [p.id, p]));
const popularPosts = popularPostSlugs
  .map(slug => postsBySlug.get(slug))
  .filter((post): post is CollectionEntry<'posts'> => post !== undefined);
---

<BaseLayout description={description} hero={true}>
  <header class="mb-12 max-md:mb-8">
    <h1 class="text-3xl md:text-4xl font-bold leading-tight text-gray-900 dark:text-gray-100">Ben Balter</h1>
    <p class="text-gray-600 dark:text-gray-300 mt-2">Engineering leadership, open source, and showing your work.</p>
  </header>
  <!-- Popular Posts Section -->
  {popularPosts.length > 0 && (
    <section class="mb-16 max-md:mb-8">
      <h2 class="text-2xl mb-2 font-semibold">
        Popular Posts
      </h2>
      <div class="w-12 h-0.5 bg-primary/40 mb-6 max-md:mb-4 rounded-full"></div>
      <div class="flex flex-wrap -mx-2">
        {popularPosts.map((post, index) => {
          const { postUrl, date, isoDate, readingTime } = getPostMetadata(post);
          return (
            <div class="w-full md:w-1/2 lg:w-1/3 px-2 mb-4 max-md:mb-3 motion-safe:animate-fade-up" style={`animation-delay: ${index * 100}ms`}>
              <PostCard
                variant="featured"
                title={post.data.title}
                url={postUrl}
                date={date}
                isoDate={isoDate}
                description={post.data.description}
                readingTime={readingTime}
              />
            </div>
          );
        })}
      </div>
    </section>
  )}

  <!-- Book Promotion -->
  <section class="mb-16 max-md:mb-8">
    <BookCta variant="featured" />
  </section>

  <!-- Recent Posts Section -->
  {featuredPosts.length > 0 && (
    <section class="mb-16 max-md:mb-8">
      <h2 class="text-2xl mb-2 font-semibold">
        Recent Posts
      </h2>
      <div class="w-12 h-0.5 bg-primary/40 mb-6 max-md:mb-4 rounded-full"></div>
      <div class="flex flex-wrap -mx-2">
        {featuredPosts.map((post, index) => {
          const { postUrl, date, isoDate, readingTime } = getPostMetadata(post);
          return (
            <div class="w-full md:w-1/2 lg:w-1/3 px-2 mb-4 max-md:mb-3 motion-safe:animate-fade-up" style={`animation-delay: ${index * 100}ms`}>
              <PostCard
                variant="featured"
                title={post.data.title}
                url={postUrl}
                date={date}
                isoDate={isoDate}
                description={post.data.description}
                readingTime={readingTime}
              />
            </div>
          );
        })}
      </div>
    </section>
  )}

  <!-- Older Posts Section -->
  {regularPosts.length > 0 && (
    <section class="pt-10 border-t border-gray-200 dark:border-gray-700">
      <h2 class="text-lg text-gray-600 dark:text-gray-300 mb-6 max-md:mb-4 font-semibold">
        Older Posts
      </h2>
      <div class="flex flex-wrap -mx-2">
        {regularPosts.slice(0, 20).map((post) => {
          const { postUrl, date, isoDate, readingTime } = getPostMetadata(post);
          return (
            <div class="w-full md:w-1/2 px-2 mb-3">
              <PostCard
                title={post.data.title}
                url={postUrl}
                date={date}
                isoDate={isoDate}
                description={post.data.description}
                readingTime={readingTime}
              />
            </div>
          );
        })}
      </div>
      {regularPosts.length > 20 && (
        <div class="text-center mt-8">
          <a href="/posts/" class="inline-flex items-center gap-1.5 rounded-lg border border-primary text-primary px-5 py-2.5 text-sm font-medium no-underline hover:bg-primary hover:text-white dark:border-primary-300 dark:text-primary-300 dark:hover:bg-primary-300 dark:hover:text-gray-900 transition-colors duration-200">
            View all {posts.length} posts
          </a>
        </div>
      )}
    </section>
  )}

  <!-- Subscribe CTA -->
  <section class="mt-12" aria-label="Subscribe">
    <SubscribeCta />
  </section>
</BaseLayout>
