---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { popularPostSlugs } from '../config';
import { getPostUrl, getDateFromSlug, formatPostDate, formatISODate } from '../utils/post-urls';
import { calculateReadingTime } from '../utils/reading-time';
import FeaturedPostCard from '../components/FeaturedPostCard.astro';
import PostCard from '../components/PostCard.astro';
import { aboutContent, getFirstSentence } from '../content/about-bio';

const description = getFirstSentence(aboutContent);

// Get all published posts (excluding archived), sorted by date (newest first)
const allPosts = await getCollection('posts', ({ data }: CollectionEntry<'posts'>) => {
  return data.published !== false && data.archived !== true;
});

// Sort posts by id (which contains date in Jekyll format YYYY-MM-DD)
const posts: CollectionEntry<'posts'>[] = allPosts.sort((a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) => 
  b.id.localeCompare(a.id)
);

// Split into featured (top 3) and regular posts
const featuredPosts = posts.slice(0, 3);
const regularPosts = posts.slice(3);

// Get popular posts based on configured slugs
const popularPosts = popularPostSlugs
  .map(slug => allPosts.find((post: CollectionEntry<'posts'>) => post.id === slug))
  .filter((post): post is CollectionEntry<'posts'> => post !== undefined);

// Helper function to get post metadata
function getPostMetadata(post: CollectionEntry<'posts'>) {
  const postDate = getDateFromSlug(post.id);
  return {
    postUrl: getPostUrl(post.id),
    date: formatPostDate(postDate),
    isoDate: formatISODate(postDate),
    readingTime: calculateReadingTime(post.body),
  };
}
---

<BaseLayout description={description} hero={true}>
  <h1 class="sr-only">Ben Balter — Technology leadership, collaboration, and open source</h1>
  <!-- Popular Posts Section -->
  {popularPosts.length > 0 && (
    <section class="mb-12 max-md:mb-8">
      <h2 class="text-2xl mb-6 max-md:mb-4 font-semibold">
        Popular Posts
      </h2>
      <div class="flex flex-wrap -mx-2">
        {popularPosts.map((post) => {
          const { postUrl, date, isoDate, readingTime } = getPostMetadata(post);
          return (
            <div class="w-full md:w-1/2 lg:w-1/3 px-2 mb-4 max-md:mb-3">
              <FeaturedPostCard
                title={post.data.title}
                url={postUrl}
                date={date}
                isoDate={isoDate}
                description={post.data.description}
                readingTime={readingTime}
              />
            </div>
          );
        })}
      </div>
    </section>
  )}

  <!-- Recent Posts Section -->
  {featuredPosts.length > 0 && (
    <section class="mb-12 max-md:mb-8">
      <h2 class="text-2xl mb-6 max-md:mb-4 font-semibold">
        Recent Posts
      </h2>
      <div class="flex flex-wrap -mx-2">
        {featuredPosts.map((post) => {
          const { postUrl, date, isoDate, readingTime } = getPostMetadata(post);
          return (
            <div class="w-full md:w-1/2 lg:w-1/3 px-2 mb-4 max-md:mb-3">
              <FeaturedPostCard
                title={post.data.title}
                url={postUrl}
                date={date}
                isoDate={isoDate}
                description={post.data.description}
                readingTime={readingTime}
              />
            </div>
          );
        })}
      </div>
    </section>
  )}

  <!-- Older Posts Section -->
  {regularPosts.length > 0 && (
    <section class="pt-8 border-t border-gray-200 dark:border-gray-700">
      <h2 class="text-lg text-gray-600 dark:text-gray-300 mb-6 max-md:mb-4 font-semibold">
        Older Posts
      </h2>
      <div class="flex flex-wrap -mx-2">
        {regularPosts.slice(0, 20).map((post) => {
          const { postUrl, date, isoDate, readingTime } = getPostMetadata(post);
          return (
            <div class="w-full md:w-1/2 px-2 mb-3">
              <PostCard
                title={post.data.title}
                url={postUrl}
                date={date}
                isoDate={isoDate}
                description={post.data.description}
                readingTime={readingTime}
              />
            </div>
          );
        })}
      </div>
      {regularPosts.length > 20 && (
        <div class="text-center mt-6">
          <a href="/posts/" class="inline-flex items-center gap-1.5 rounded-lg border border-primary text-primary px-5 py-2.5 text-sm font-medium no-underline hover:bg-primary hover:text-white dark:border-primary-300 dark:text-primary-300 dark:hover:bg-primary-300 dark:hover:text-gray-900 transition-colors duration-200">
            View all {posts.length} posts
          </a>
        </div>
      )}
    </section>
  )}
</BaseLayout>
