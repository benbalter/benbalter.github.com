---
/**
 * LinkedIn-Friendly Resume Page
 *
 * Displays resume data in a format optimized for easy copy-paste into LinkedIn
 * profile fields. Each field has a copy button and a character counter where
 * LinkedIn enforces a limit. Utility page, not indexed by search engines.
 */

import PageLayout from '../../layouts/PageLayout.astro';
import LinkedInField from '../../components/LinkedInField.astro';
import { getEntry, getCollection, type CollectionEntry } from 'astro:content';
import { formatResumeDate } from '../../utils/post-urls';
import { cleanDescription, LINKEDIN_LIMITS } from '../../utils/linkedin-format';
import { linkedinHeadline, linkedinAboutHtml } from '../../content/linkedin-bio';

const resumePage = await getEntry('pages', 'resume');
if (!resumePage) {
  throw new Error('Resume page data not found');
}

const { degrees, certifications, skills } = resumePage.data;

const allPositions = await getCollection('resume-positions');
const sortedPositions = allPositions.sort((a: CollectionEntry<'resume-positions'>, b: CollectionEntry<'resume-positions'>) => {
  return new Date(b.data.start_date).getTime() - new Date(a.data.start_date).getTime();
});

interface PositionData {
  title: string;
  employer: string;
  startDate: string;
  endDate: string;
  description: string;
}

const positionsData: PositionData[] = sortedPositions.map((position: CollectionEntry<'resume-positions'>) => ({
  title: position.data.title,
  employer: position.data.employer,
  startDate: formatResumeDate(position.data.start_date) || 'Unknown',
  endDate: position.data.end_date ? (formatResumeDate(position.data.end_date) || 'Unknown') : 'Present',
  description: cleanDescription(position.body),
}));

interface EducationData {
  school: string;
  degree: string;
  endDate: string;
}

const educationData: EducationData[] = degrees?.map((degree: { school: string; degree: string; date: string }) => ({
  school: degree.school,
  degree: degree.degree,
  endDate: formatResumeDate(degree.date) || 'Unknown',
})) || [];

interface Cert {
  authority: string;
  name: string;
  url?: string;
  category?: 'professional' | 'personal';
  expired?: boolean;
}

const allCerts: Cert[] = (certifications ?? []) as Cert[];
const professionalCerts = allCerts.filter(c => c.category !== 'personal');
const personalCerts = allCerts.filter(c => c.category === 'personal');

// Skills grouped by category, plus a flat combined list for a "copy all" field.
interface SkillGroup { group: string; items: string[] }
const skillGroups: SkillGroup[] = (skills ?? []) as SkillGroup[];
const allSkills = skillGroups.flatMap(g => g.items);
---

<PageLayout
  title="Resume — LinkedIn Format"
  description="Resume data formatted for easy LinkedIn profile updates."
  noindex={true}
>
  <div class="bg-gray-50 dark:bg-gray-800 border-l-4 border-primary rounded px-5 py-4 mb-8">
    <p class="m-0 text-gray-900 dark:text-gray-100">
      This page formats resume data for easy copy-paste into your LinkedIn profile.
      Click the 📋 icon next to any field to copy its contents to your clipboard.
    </p>
  </div>

  <!-- Profile Section -->
  <section class="mb-12">
    <h2 class="text-3xl font-semibold mt-10 mb-6 text-gray-900 dark:text-gray-100 border-b-2 border-gray-300 dark:border-gray-600 pb-2">Profile</h2>

    <div class="bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg p-6 mb-6 shadow-card">
      <LinkedInField label="Headline" value={linkedinHeadline} limit={LINKEDIN_LIMITS.headline} />
      <LinkedInField label="About" html={linkedinAboutHtml} limit={LINKEDIN_LIMITS.about} marginClass="" />
    </div>
  </section>

  <!-- Experience Section -->
  <section class="mb-12">
    <h2 class="text-3xl font-semibold mt-10 mb-6 text-gray-900 dark:text-gray-100 border-b-2 border-gray-300 dark:border-gray-600 pb-2">Experience</h2>

    {positionsData.map((position: PositionData) => (
      <div class="bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg p-6 mb-6 shadow-card">
        <LinkedInField label="Title" value={position.title} />
        <LinkedInField label="Company" value={position.employer} />
        <LinkedInField label="Start date" value={position.startDate} />
        <LinkedInField label="End date" value={position.endDate} />
        <LinkedInField label="Description" html={position.description} limit={LINKEDIN_LIMITS.description} marginClass="" />
      </div>
    ))}
  </section>

  <!-- Skills Section -->
  {skillGroups.length > 0 && (
    <section class="mb-12">
      <h2 class="text-3xl font-semibold mt-10 mb-6 text-gray-900 dark:text-gray-100 border-b-2 border-gray-300 dark:border-gray-600 pb-2">Skills</h2>

      <div class="bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg p-6 mb-6 shadow-card">
        <p class="text-sm text-gray-700 dark:text-gray-300 mb-4">
          LinkedIn allows up to 50 skills. Add them one at a time via <em>Profile → Add profile section → Core → Skills</em>,
          or copy the combined list below to paste into your resume.
        </p>

        <LinkedInField
          label="All skills (one per line)"
          html={allSkills.join('<br>')}
          copyLabel="Copy all skills to clipboard"
        />

        {skillGroups.map((group: SkillGroup) => (
          <div class="mb-5">
            <span class="block text-sm font-semibold text-gray-600 dark:text-gray-300 uppercase tracking-wide mb-2">{group.group}</span>
            <ul class="list-none p-0 m-0 space-y-2">
              {group.items.map((skill: string) => (
                <li class="flex items-start gap-3">
                  <div class="flex-1 text-base text-gray-900 dark:text-gray-100 leading-relaxed px-3 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded-md break-words">{skill}</div>
                  <button class="copy-btn shrink-0 bg-primary text-white border-none rounded-md px-3 py-2 text-xl leading-none cursor-pointer transition-all duration-200 min-w-10 h-10 flex items-center justify-center hover:bg-primary-600 hover:scale-105 active:scale-95" data-copy={skill} aria-label={`Copy skill ${skill} to clipboard`}>📋</button>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Education Section -->
  {educationData.length > 0 && (
    <section class="mb-12">
      <h2 class="text-3xl font-semibold mt-10 mb-6 text-gray-900 dark:text-gray-100 border-b-2 border-gray-300 dark:border-gray-600 pb-2">Education</h2>

      {educationData.map((degree: EducationData) => (
        <div class="bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg p-6 mb-6 shadow-card">
          <LinkedInField label="School" value={degree.school} />
          <LinkedInField label="Degree" value={degree.degree} />
          <LinkedInField label="End date" value={degree.endDate} marginClass="" />
        </div>
      ))}
    </section>
  )}

  <!-- Certifications Section -->
  {allCerts.length > 0 && (
    <section class="mb-12">
      <h2 class="text-3xl font-semibold mt-10 mb-6 text-gray-900 dark:text-gray-100 border-b-2 border-gray-300 dark:border-gray-600 pb-2">Certifications</h2>

      {professionalCerts.length > 0 && (
        <>
          <h3 class="text-lg font-semibold text-gray-700 dark:text-gray-300 mb-3 mt-4">Professional</h3>
          {professionalCerts.map((cert: Cert) => (
            <div class="bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg p-6 mb-6 shadow-card">
              <LinkedInField
                label={cert.expired ? 'Name (Expired)' : 'Name'}
                value={cert.name}
              />
              <LinkedInField label="Issuing organization" value={cert.authority} marginClass={cert.url ? 'mb-5' : ''} />
              {cert.url && (
                <LinkedInField label="Credential URL" value={cert.url} marginClass="" />
              )}
            </div>
          ))}
        </>
      )}

      {personalCerts.length > 0 && (
        <>
          <h3 class="text-lg font-semibold text-gray-700 dark:text-gray-300 mb-3 mt-6">Personal</h3>
          {personalCerts.map((cert: Cert) => (
            <div class="bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg p-6 mb-6 shadow-card">
              <LinkedInField
                label={cert.expired ? 'Name (Expired)' : 'Name'}
                value={cert.name}
              />
              <LinkedInField label="Issuing organization" value={cert.authority} marginClass={cert.url ? 'mb-5' : ''} />
              {cert.url && (
                <LinkedInField label="Credential URL" value={cert.url} marginClass="" />
              )}
            </div>
          ))}
        </>
      )}
    </section>
  )}
</PageLayout>

<script>
  import '../../scripts/linkedin-copy';
</script>
