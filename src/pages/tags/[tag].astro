---
/**
 * Individual Tag Page
 * 
 * Displays all posts with a specific tag, using the same PostCard
 * component as the main posts archive.
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { getPostUrl, getDateFromSlug, formatPostDate, formatISODate } from '../../utils/post-urls';
import { calculateReadingTime } from '../../utils/reading-time';
import PostCard from '../../components/PostCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');

  // Build tag → posts map
  const tagPosts = new Map<string, typeof posts>();
  const tagNames = new Map<string, string>();

  for (const post of posts) {
    const tags = post.data.tags ?? [];
    for (const tag of tags) {
      const slug = tag.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
      if (!tagPosts.has(slug)) {
        tagPosts.set(slug, []);
      }
      tagPosts.get(slug)!.push(post);
      if (!tagNames.has(slug)) {
        tagNames.set(slug, tag);
      }
    }
  }

  return [...tagPosts.entries()].map(([slug, taggedPosts]) => ({
    params: { tag: slug },
    props: {
      tagName: tagNames.get(slug) ?? slug,
      posts: taggedPosts.sort((a, b) => b.slug.localeCompare(a.slug)),
    },
  }));
}

const { tagName, posts } = Astro.props;

const title = `Posts tagged "${tagName}"`;
const description = `All ${posts.length} blog posts tagged with "${tagName}".`;

const postsWithMeta = posts.map((post: any) => {
  const postDate = getDateFromSlug(post.slug);
  return {
    title: post.data.title,
    url: getPostUrl(post.slug),
    date: formatPostDate(postDate),
    isoDate: formatISODate(postDate),
    description: post.data.description,
    readingTime: calculateReadingTime(post.body),
  };
});
---

<BaseLayout title={title} description={description}>
  <div class="container mx-auto max-w-4xl px-4 py-8">
    <header class="mb-8">
      <nav class="mb-4">
        <a href="/tags/" class="text-sm text-primary dark:text-primary-300 hover:text-primary-700 dark:hover:text-primary-200 no-underline inline-flex items-center gap-1 transition-colors duration-200">
          <span aria-hidden="true">←</span> All tags
        </a>
      </nav>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-2" transition:name="page-title">
        <span class="inline-flex items-center gap-2">
          {tagName}
          <span class="inline-flex items-center justify-center rounded-full bg-primary/10 dark:bg-primary/20 px-3 py-1 text-sm font-medium text-primary-700 dark:text-primary-300">
            {posts.length}
          </span>
        </span>
      </h1>
    </header>

    <div class="flex flex-wrap -mx-2">
      {postsWithMeta.map((post) => (
        <div class="w-full md:w-1/2 px-2 mb-3">
          <PostCard
            title={post.title}
            url={post.url}
            date={post.date}
            isoDate={post.isoDate}
            description={post.description}
            readingTime={post.readingTime}
          />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
