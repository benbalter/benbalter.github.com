---
import PageLayout from '../layouts/PageLayout.astro';
import { slugify } from '../utils/slugify';

const title = 'Talks and Presentations';
const description = 'Slides and recordings from some of the talks I\'ve given over the years.';

interface Talk {
  title: string;
  url: string;
  extra?: { label: string; url: string }[];
}

interface TalkGroup {
  category: string;
  emoji: string;
  talks: Talk[];
}

const talkGroups: TalkGroup[] = [
  {
    category: 'Community management',
    emoji: '🤝',
    talks: [
      { title: 'A community of communities: Empowering maintainers to grow communities around their code', url: '/2019/07/18/a-community-of-communities-oscon-2019/' },
      { title: 'It takes a digital village: An analytical-ish look at what grows strong communities on GitHub.com', url: 'https://speakerdeck.com/benbalter/it-takes-a-digital-village' },
      { title: 'Growing open source communities on GitHub around your WordPress plugin or theme', url: 'https://speakerdeck.com/benbalter/growing-open-source-communities-on-github-around-your-wordpress-plugin-or-theme' },
    ],
  },
  {
    category: 'Collaboration and open source',
    emoji: '🌐',
    talks: [
      { title: 'Fostering a culture of collaboration', url: 'https://speakerdeck.com/benbalter/fostering-a-culture-of-collaboration' },
      { title: 'Closed source (just) a few things', url: 'https://speakerdeck.com/benbalter/closed-source-a-few-things' },
      { title: 'Best practices for open source in government', url: 'https://speakerdeck.com/benbalter/best-practices-for-open-source-in-government' },
      { title: 'Open source licensing by the numbers', url: 'https://speakerdeck.com/benbalter/open-source-licensing-by-the-numbers' },
      { title: 'Open source demystified: from command-line to community engagement', url: '/open-source-demistified/', extra: [{ label: 'source', url: 'https://github.com/benbalter/open-source-demistified/' }] },
      { title: 'Open collaboration: why you should give open source a second look', url: 'https://www.slideshare.net/TechSummitPR/pr-35485194' },
    ],
  },
  {
    category: 'Software development and workflows',
    emoji: '⚙️',
    talks: [
      { title: 'How to work like an open source project, regardless of what you do', url: 'https://speakerdeck.com/benbalter/how-to-work-like-an-open-source-project' },
      { title: 'How GitHub works like an open source project', url: 'https://speakerdeck.com/benbalter/how-github-works-like-an-open-source-project' },
      { title: 'Three simple rules for building APIs', url: 'https://speakerdeck.com/benbalter/three-simple-rules-for-building-apis' },
      { title: 'Code, Test, Deploy: How to :ship: software like a startup', url: 'https://speakerdeck.com/benbalter/code-test-deploy' },
      { title: 'Rapid development, testing, and deployment the open source way', url: 'https://speakerdeck.com/benbalter/open-sourcing-government' },
    ],
  },
  {
    category: 'Open government',
    emoji: '🏛️',
    talks: [
      { title: 'What government can learn from open source', url: 'https://www.youtube.com/watch?v=E3ftpYQyLOc', extra: [{ label: 'slides', url: 'https://speakerdeck.com/benbalter/what-government-can-learn-from-open-source' }] },
      { title: 'Software developer as civic service', url: 'https://speakerdeck.com/benbalter/software-development-as-civic-service' },
      { title: 'The revolution will be forked: how open collaboration is reimagining the way government works', url: '/open-sourcing-government/', extra: [{ label: 'source', url: 'https://github.com/benbalter/open-sourcing-government/' }] },
      { title: 'Make Government better together: Moving from open government to collaborative government', url: '/make-government-better-together/', extra: [{ label: 'source', url: 'https://github.com/benbalter/make-government-better-together/' }] },
    ],
  },
  {
    category: 'Law and policy',
    emoji: '📜',
    talks: [
      { title: 'Open source software licensing: empowering others to use your code', url: '/open-source-software-licensing/', extra: [{ label: 'source', url: 'https://github.com/benbalter/open-source-software-licensing/' }] },
      { title: 'Collaborative policy making: how technology is making it easier to work together than alone', url: '/collaborative-policymaking/', extra: [{ label: 'source', url: 'https://github.com/benbalter/collaborative-policymaking/' }] },
      { title: 'Project open data: a case study in collaborative governance', url: 'https://www.youtube.com/watch?v=EL3-UwY3qGE', extra: [{ label: 'video', url: 'https://www.youtube.com/watch?v=EL3-UwY3qGE' }] },
    ],
  },
  {
    category: 'Mapping and GeoJSON',
    emoji: '🗺️',
    talks: [
      { title: "Open source, open standards, and 50 lines of code: a look behind GitHub's GeoJSON rendering and diffing", url: '/behind-github-GeoJSON/', extra: [{ label: 'source', url: 'https://github.com/benbalter/behind-github-GeoJSON/' }] },
      { title: 'Make maps better together: Collaborative mapping the Open Source Way', url: '/make-maps-better-together/', extra: [{ label: 'video', url: 'https://www.youtube.com/watch?v=iGRb5QRqC2w' }] },
    ],
  },
  {
    category: 'Miscellaneous',
    emoji: '✨',
    talks: [
      { title: 'A benbalter-centric history of GitHub Pages and Autoblog', url: 'https://speakerdeck.com/benbalter/an-at-benbalter-centric-history-of-github-pages-and-autoblog' },
      { title: 'The next cultural commons: how the internet has been quietly assembling the next cultural cannon', url: '/the-next-cultural-commons/', extra: [{ label: 'source', url: 'https://github.com/benbalter/the-next-cultural-commons/' }] },
    ],
  },
];

const totalTalks = talkGroups.reduce((sum, g) => sum + g.talks.length, 0);
---

<PageLayout title={title} description={description}>
  <div class="not-prose">
    <p class="text-gray-600 dark:text-gray-300 mb-8">
      Slides (and recordings) from {totalTalks}+ talks I've given over the years. Have a suggestion? <a href="https://github.com/benbalter/talks/issues" class="text-primary dark:text-primary-300 hover:text-primary-700 dark:hover:text-primary-200 underline">I'd love to hear it</a>.
    </p>

    {/* Category navigation */}
    <nav class="mb-10" aria-label="Talk categories">
      <ul class="flex flex-wrap gap-2 list-none p-0 m-0">
        {talkGroups.map(({ category, emoji }) => (
          <li>
            <a
              href={`#${slugify(category)}`}
              class="inline-flex items-center gap-1.5 rounded-full border border-gray-200 bg-gray-50 px-4 py-1.5 text-sm font-medium text-gray-700 no-underline transition-colors duration-200 hover:border-primary hover:bg-primary hover:text-white dark:border-gray-600 dark:bg-gray-800 dark:text-gray-300 dark:hover:border-primary-400 dark:hover:bg-primary-400 dark:hover:text-gray-900"
            >
              <span aria-hidden="true">{emoji}</span> {category}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    {/* Talk sections */}
    {talkGroups.map(({ category, emoji, talks }) => (
      <section class="mb-10">
        <div class="mb-4 flex items-baseline gap-3 border-l-4 border-primary pl-4">
          <h2 id={slugify(category)} class="m-0 text-xl font-semibold text-gray-900 dark:text-gray-100">
            <span aria-hidden="true">{emoji}</span> {category}
          </h2>
          <span class="text-sm text-gray-600 dark:text-gray-300">
            · {talks.length} {talks.length === 1 ? 'talk' : 'talks'}
          </span>
        </div>

        <div class="space-y-3">
          {talks.map((talk) => (
            <div class="group relative rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-4 transition-all duration-200 hover:border-primary/40 dark:hover:border-primary-400/40 hover:shadow-sm">
              <h3 class="m-0 text-[0.95rem] font-medium leading-snug">
                <a
                  href={talk.url}
                  class="text-gray-900 dark:text-gray-100 no-underline group-hover:text-primary dark:group-hover:text-primary-300 transition-colors duration-200 before:absolute before:inset-0"
                  {...(talk.url.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {talk.title}
                </a>
              </h3>
              {talk.extra && talk.extra.length > 0 && (
                <div class="mt-1.5 flex gap-2 relative z-10">
                  {talk.extra.map(({ label, url }) => (
                    <a
                      href={url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-1 rounded-full bg-gray-100 dark:bg-gray-700 px-2.5 py-0.5 text-xs font-medium text-gray-700 dark:text-gray-300 no-underline hover:bg-primary/10 hover:text-primary dark:hover:text-primary-300 transition-colors duration-150"
                    >
                      {label}
                    </a>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </section>
    ))}

    {/* More talks CTA */}
    <div class="text-center">
      <a
        href="https://speakerdeck.com/benbalter"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-primary dark:text-primary-300 font-semibold no-underline hover:text-primary-700 dark:hover:text-primary-200 transition-colors duration-200"
      >
        More talks on Speaker Deck <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</PageLayout>
