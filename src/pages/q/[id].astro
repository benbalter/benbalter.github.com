---
/**
 * Standalone share page for a single quote: /q/<id>
 *
 * These pages exist to be *share targets*, not search landing pages — their
 * body is a verbatim line already indexed on the source post. So they're
 * `noindex, follow` (the `follow` passes link equity back to the post) and
 * excluded from the sitemap (see EXCLUDED_PAGES in astro.config.mjs). Social
 * and OG crawlers read the meta tags regardless of `noindex`, so sharing is
 * unaffected.
 */

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import SubscribeCta from '../../components/SubscribeCta.astro';
import Icon from '../../components/Icon.astro';
import { siteConfig } from '../../config';
import { resolveQuotes, type ResolvedQuote } from '../../utils/quotes';
import { quoteAnchorId } from '../../lib/remark-quote-directive';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  // resolveQuotes validates every registry entry against a real, listable
  // post — a dangling or non-listable reference fails the build here.
  return resolveQuotes(posts).map((quote) => ({
    params: { id: quote.id },
    props: { quote },
  }));
}

interface Props {
  quote: ResolvedQuote;
}

const { quote } = Astro.props;
const attribution = siteConfig.author;

const pageUrl = new URL(`/q/${quote.id}/`, siteConfig.url).toString();
// Deep-link back to the highlighted line in the post so readers land in context.
const sourceUrl = `${quote.postUrl}#${quoteAnchorId(quote.id)}`;
const ogImage = `/og/q/${quote.id}.png`;
---

<BaseLayout
  title={quote.text}
  description={`${quote.text} — ${attribution}`}
  image={ogImage}
  robots="noindex, follow"
>
  <div class="max-w-2xl mx-auto px-4">
    <figure class="quote-hero">
      <blockquote>
        <p>{quote.text}</p>
      </blockquote>
      <figcaption class="quote-attribution">— {attribution}</figcaption>
    </figure>

    <p class="quote-source">
      From <a href={sourceUrl}>{quote.postTitle}</a>
    </p>

    <div class="quote-actions">
      <ShareButtons title={quote.text} url={pageUrl} />
      <a href="/quotes/" class="quote-more">
        <Icon name="share-nodes" />
        <span>More quotes</span>
      </a>
    </div>

    <div class="mt-12">
      <SubscribeCta />
    </div>
  </div>
</BaseLayout>

<style>
  @reference "../../styles/global.css";

  .quote-hero {
    @apply mt-6 mb-8 pl-6 md:pl-8;
    border-left: 5px solid var(--color-primary);
  }

  .quote-hero blockquote {
    @apply m-0 p-0 border-0;
  }

  .quote-hero blockquote p {
    @apply m-0 font-sans not-italic font-bold tracking-tight leading-tight;
    @apply text-3xl md:text-4xl lg:text-5xl;
    @apply text-gray-900 dark:text-gray-100;
  }

  .quote-attribution {
    @apply mt-4 font-sans text-lg font-semibold text-gray-600 dark:text-gray-300;
  }

  .quote-source {
    @apply font-sans text-base text-gray-600 dark:text-gray-300 mb-8;
  }

  .quote-actions {
    @apply flex flex-wrap items-center justify-between gap-4;
    @apply border-t border-gray-200 dark:border-gray-700 pt-6;
  }

  .quote-more {
    @apply inline-flex items-center gap-1.5 text-sm font-semibold no-underline;
    @apply text-gray-600 dark:text-gray-300 transition-colors duration-200;
  }

  .quote-more:hover {
    @apply text-primary dark:text-primary-300;
  }
</style>
