---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import PostLayout from '../../../../layouts/PostLayout.astro';
import { findRelatedPosts, initializeRelatedPostsCache } from '../../../../utils/related-posts';
import { getPostUrl } from '../../../../utils/post-urls';
import { isPublishedPost } from '../../../../utils/post-filtering';
import { calculateReadingTime } from '../../../../utils/reading-time';

// Generate static paths for all blog posts with Jekyll URL structure
export async function getStaticPaths() {
  const posts = await getCollection('posts', isPublishedPost);

  // Initialize the related posts cache once for all posts
  // This pre-calculates TF-IDF vectors for all posts to avoid redundant computation
  initializeRelatedPostsCache(posts);

  return posts.map((post: CollectionEntry<'posts'>) => {
    // Extract date from id (YYYY-MM-DD-slug format)
    const dateMatch = post.id.match(/^(\d{4})-(\d{2})-(\d{2})-(.+)$/);
    
    if (dateMatch) {
      const [, year, month, day, slug] = dateMatch;
      return {
        params: { year, month, day, slug },
        props: { post, allPosts: posts },
      };
    }
    
    // Fallback for posts without date in id
    console.warn(`Post ${post.id} does not match expected format YYYY-MM-DD-slug`);
    return null;
  }).filter(Boolean);
}

interface Props {
  post: CollectionEntry<'posts'>;
  allPosts: CollectionEntry<'posts'>[];
}

const { post, allPosts } = Astro.props;
const { Content } = await render(post);

// Extract date from params for display (use URL params to ensure consistency with the route)
const { year, month, day, slug } = Astro.params;
const pubDate = new Date(parseInt(year), parseInt(month) - 1, parseInt(day));

// Generate OG image URL for this post
// If post has a custom image, use that, otherwise use the dynamically generated one
const ogImageUrl = post.data.image || `/og/${year}/${month}/${day}/${slug}.png`;

// Find related posts (limit to 10) - uses cached TF-IDF calculations
const relatedPosts = await findRelatedPosts(post, allPosts, 10);

// Find previous and next posts for sequential navigation
const publishedPosts = allPosts
  .filter((p: CollectionEntry<'posts'>) => p.data.published !== false)
  .sort((a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) => a.id.localeCompare(b.id));

const currentIndex = publishedPosts.findIndex((p: CollectionEntry<'posts'>) => p.id === post.id);
const prevEntry = currentIndex > 0 ? publishedPosts[currentIndex - 1] : undefined;
const nextEntry = currentIndex < publishedPosts.length - 1 ? publishedPosts[currentIndex + 1] : undefined;
const prevPost = prevEntry ? { title: prevEntry.data.title, url: getPostUrl(prevEntry.id), readingTime: calculateReadingTime(prevEntry.body ?? '') } : undefined;
const nextPost = nextEntry ? { title: nextEntry.data.title, url: getPostUrl(nextEntry.id), readingTime: calculateReadingTime(nextEntry.body ?? '') } : undefined;
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  tldr={post.data.tldr}
  pubDate={pubDate}
  image={ogImageUrl}
  relatedPosts={relatedPosts}
  prevPost={prevPost}
  nextPost={nextPost}
  archived={post.data.archived}
  postId={post.id}
  postFilePath={post.filePath}
  posts={post.data.posts}
  roles={post.data.roles}
>
  <Content />
</PostLayout>
