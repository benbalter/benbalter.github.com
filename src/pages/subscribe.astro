---
/**
 * Subscribe landing page
 *
 * A dedicated, shareable URL for the subscribe form — linkable from social
 * bios, talk slides, and email signatures. Composes the same SubscribeCta
 * used on posts and the homepage.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import SubscribeCta from '../components/SubscribeCta.astro';

const title = 'Subscribe';
const description =
  'Get new posts from Ben Balter on engineering leadership, open source, and showing your work — by email, RSS, or social. No spam, unsubscribe anytime.';
---

<BaseLayout title={title} description={description}>
  <div class="max-w-2xl mx-auto">
    <header class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold leading-tight text-gray-900 dark:text-gray-100">
        {title}
      </h1>
      <p class="mt-4 text-gray-600 dark:text-gray-300">
        I write about engineering leadership, open source, and working
        openly and asynchronously—practical playbooks over hot takes. Posts are
        occasional, not on a schedule, which is exactly why subscribing beats
        remembering to check back.
      </p>
    </header>

    <SubscribeCta />

    <p class="mt-8 text-sm text-gray-600 dark:text-gray-300">
      Not sure yet? Start with the <a href="/posts/">most popular posts</a> and
      see if it's your kind of thing.
    </p>
  </div>
</BaseLayout>
