---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { getDateFromSlug, getPostUrl } from '../utils/post-urls';
import { isPublishedPost } from '../utils/post-filtering';
import { getPostMetadata } from '../utils/post-metadata';
import PostCard from '../components/PostCard.astro';
import { popularPostSlugs, siteConfig } from '../config';
import { generateCollectionPageSchema, schemaToJsonLd } from '../utils/structured-data';

const title = 'Blog';
const description = 'Blog posts on technology leadership, open source, remote work, and collaboration by Ben Balter — from practical management advice to engineering culture.';

const allPosts = await getCollection('posts', isPublishedPost);

const posts: CollectionEntry<'posts'>[] = allPosts.sort((a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) =>
  b.id.localeCompare(a.id)
);

const popularPosts = popularPostSlugs
  .map(slug => allPosts.find((post: CollectionEntry<'posts'>) => post.id === slug))
  .filter((post): post is CollectionEntry<'posts'> => post !== undefined);

const postsByYear = new Map<number, CollectionEntry<'posts'>[]>();
for (const post of posts) {
  const year = getDateFromSlug(post.id).getFullYear();
  if (!postsByYear.has(year)) {
    postsByYear.set(year, []);
  }
  postsByYear.get(year)!.push(post);
}
const years = [...postsByYear.keys()].sort((a, b) => b - a);

const collectionSchema = generateCollectionPageSchema({
  name: title,
  description,
  url: new URL('/posts/', siteConfig.url).toString(),
  posts: posts.map(post => ({
    url: new URL(getPostUrl(post.id), siteConfig.url).toString(),
    title: post.data.title,
  })),
});
---

<BaseLayout title={title} description={description}>
  <header class="mb-8">
    <h1 class="text-3xl md:text-4xl font-bold leading-tight text-gray-900 dark:text-gray-100">{title}</h1>
    <p class="text-gray-600 dark:text-gray-300">{posts.length} posts</p>
  </header>

  <nav aria-label="Jump to year" class="mb-8 flex flex-wrap gap-2">
    {years.map((year) => (
      <a
        href={`#${year}`}
        class="text-sm px-3 py-1 rounded-full border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:border-primary hover:text-primary dark:hover:border-primary-300 dark:hover:text-primary-300 no-underline transition-colors focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-2"
      >
        {year}
      </a>
    ))}
  </nav>

  {popularPosts.length > 0 && (
    <section class="mb-12">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-4">Popular Posts</h2>
      <div class="flex flex-wrap -mx-2">
        {popularPosts.map((post) => {
          const { postUrl, date, isoDate, readingTime } = getPostMetadata(post);
          return (
            <div class="w-full md:w-1/2 lg:w-1/3 px-2 mb-3">
              <PostCard
                variant="featured"
                title={post.data.title}
                url={postUrl}
                date={date}
                isoDate={isoDate}
                description={post.data.description}
                readingTime={readingTime}
              />
            </div>
          );
        })}
      </div>
    </section>
  )}

  {years.map((year) => {
    const yearPosts = postsByYear.get(year)!;
    return (
      <section class="mb-10">
        <h2 id={`${year}`} class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-4">
          {year} ({yearPosts.length} {yearPosts.length === 1 ? 'post' : 'posts'})
        </h2>
        <div class="flex flex-wrap -mx-2">
          {yearPosts.map((post) => {
            const { postUrl, date, isoDate, readingTime } = getPostMetadata(post);
            return (
              <div class="w-full md:w-1/2 px-2 mb-3">
                <PostCard
                  title={post.data.title}
                  url={postUrl}
                  date={date}
                  isoDate={isoDate}
                  description={post.data.description}
                  readingTime={readingTime}
                />
              </div>
            );
          })}
        </div>
      </section>
    );
  })}
  <script type="application/ld+json" set:html={schemaToJsonLd(collectionSchema)} is:inline></script>
</BaseLayout>
