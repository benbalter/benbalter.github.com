---
/**
 * Other Recommended Reading Page
 * 
 * Displays a curated list of book recommendations organized by category.
 * Books are loaded from src/data/books.yml and displayed in a responsive grid.
 */

import PageLayout from '../layouts/PageLayout.astro';
import { readFileSync } from 'node:fs';
import yaml from 'js-yaml';
import { join } from 'node:path';
import { marked } from 'marked';

const title = 'Other recommended reading';
const description = 'Here are some of the books that have had a significant influence on my career, management style, and professional development that I often recommend to others interested in IT management and leadership, career and corporate life, open source, startups and innovation, information security, product management, marketing, technology policy, government and organizing, and everything else.';

interface Book {
  title: string;
  asin: string;
  tldr: string;
}

type BooksData = Record<string, Book[]>;

// Load books data from src/data/books.yml
const booksPath = join(process.cwd(), 'src', 'data', 'books.yml');
let booksData: BooksData;
try {
  const booksYaml = readFileSync(booksPath, 'utf-8');
  // js-yaml v4+ uses safe schema by default for load()
  // This prevents arbitrary code execution and only constructs safe JavaScript types
  // See: https://github.com/nodeca/js-yaml/blob/master/CHANGELOG.md#400---2021-01-03
  booksData = yaml.load(booksYaml) as BooksData;
} catch (error) {
  throw new Error(`Failed to load books data from ${booksPath}: ${error instanceof Error ? error.message : String(error)}`);
}

// Amazon affiliate tag
const amazonAffiliatesTag = 'benbalter07-20';

// Convert object to array of [category, books] entries
const bookGroups = Object.entries(booksData);

// Helper function to slugify category names for IDs
function slugify(text: string): string {
  return text
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
}
---

<PageLayout title={title} description={description}>

  {/* Category navigation pills */}
  <nav class="not-prose mb-10" aria-label="Book categories">
    <ul class="flex flex-wrap gap-2 list-none p-0 m-0">
      {bookGroups.map(([category]) => (
        <li>
          <a
            href={`#${slugify(category)}`}
            class="inline-block rounded-full border border-gray-200 bg-gray-50 px-4 py-1.5 text-sm font-medium text-gray-700 no-underline transition-colors duration-200 hover:border-primary hover:bg-primary hover:text-white dark:border-gray-600 dark:bg-gray-800 dark:text-gray-300 dark:hover:border-primary-400 dark:hover:bg-primary-400 dark:hover:text-gray-900"
          >
            {category}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  {bookGroups.map(([category, books]) => (
    <section class="not-prose mb-12">
      <div class="mb-6 flex items-baseline gap-3 border-l-4 border-primary pl-4">
        <h3
          id={slugify(category)}
          class="m-0 text-2xl font-semibold text-gray-900 dark:text-gray-100"
        >
          {category}
        </h3>
        <span class="text-sm text-gray-600 dark:text-gray-300">
          · {books.length} {books.length === 1 ? 'book' : 'books'}
        </span>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {books.map((book) => (
          <div class="group relative flex flex-col overflow-hidden rounded-lg border border-gray-200 bg-white p-5 transition-all duration-200 hover:border-primary/40 hover:shadow-[0_6px_16px_rgba(0,0,0,0.12)] motion-safe:hover:-translate-y-0.5 dark:border-gray-700 dark:bg-gray-800 dark:hover:border-primary-400/40 dark:hover:shadow-[0_6px_16px_rgba(0,0,0,0.4)]">
            <div class="mb-4 flex items-center justify-center">
              <img
                src={`https://images.amazon.com/images/P/${book.asin}.01.MZZZZZZZ.jpg`}
                alt={`${book.title} book cover`}
                width="160"
                height="240"
                loading="lazy"
                class="max-h-52 w-auto rounded shadow-card"
              />
            </div>

            <h4 class="mb-2 text-center text-[0.95rem] font-semibold leading-snug">
              <a
                href={`https://www.amazon.com/gp/product/${book.asin}/?tag=${amazonAffiliatesTag}`}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${book.title} on Amazon`}
                class="text-gray-900 no-underline transition-colors duration-200 before:absolute before:inset-0 group-hover:text-primary dark:text-gray-100 dark:group-hover:text-primary-300"
              >
                {book.title}
              </a>
            </h4>

            <p
              class="m-0 text-sm leading-relaxed text-gray-600 dark:text-gray-300"
              set:html={marked.parseInline(book.tldr)}
            />
          </div>
        ))}
      </div>
    </section>
  ))}
</PageLayout>
