---
import PageLayout from '../layouts/PageLayout.astro';
import { siteConfig } from '../config';
import { Image } from 'astro:assets';
import headshotImage from '../../assets/img/headshot.jpg';
import ContactLinks from '../components/ContactLinks.astro';
import { getBioParagraphs, aboutContent } from '../content/about-bio';
import { getCollection, type CollectionEntry } from 'astro:content';
import { getPostUrl, getDateFromSlug, formatPostDate } from '../utils/post-urls';

const title = 'About';
const description = siteConfig.aboutDescription;
const bioParagraphs = getBioParagraphs(aboutContent);

const allPosts = await getCollection('posts', ({ data }: CollectionEntry<'posts'>) => {
  return data.published !== false && data.archived !== true;
});

const recentPosts = allPosts
  .sort((a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) => b.slug.localeCompare(a.slug))
  .slice(0, 5);
---

<PageLayout title={title} description={description}>
  <div class="grid gap-6 md:grid-cols-[1fr_250px]">
    <div>
      {bioParagraphs.map(paragraph => (
        <p set:html={paragraph}></p>
      ))}

      <p>
        Feel free to email him at <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a> or you can find him on these social networks:
      </p>

      <ContactLinks />
    </div>

    <div class="row-start-1 md:row-start-auto max-w-[200px] mx-auto md:max-w-none md:mx-0 md:self-start">
      <a href={`${siteConfig.githubRepoUrl}/raw/master/assets/img/headshot.jpg`}>
        <Image src={headshotImage} alt={`${siteConfig.author} headshot`} width={250} height={250} class="w-full rounded" />
      </a>
    </div>
  </div>

  <section class="mt-10 pt-8 border-t border-gray-200 dark:border-gray-700">
    <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4">Latest Posts</h2>
    <ul class="space-y-2 list-none p-0 m-0">
      {recentPosts.map((post) => {
        const postDate = getDateFromSlug(post.slug);
        return (
          <li class="flex items-baseline gap-3">
            <time datetime={postDate.toISOString()} class="text-sm text-gray-600 dark:text-gray-300 shrink-0">{formatPostDate(postDate)}</time>
            <a href={getPostUrl(post.slug)} class="text-primary hover:text-primary-700 dark:text-primary-300 dark:hover:text-primary-200 transition-colors duration-200">{post.data.title}</a>
          </li>
        );
      })}
    </ul>
    <p class="mt-4">
      <a href="/posts/" class="btn btn-outline-primary btn-sm">View all posts →</a>
    </p>
  </section>
</PageLayout>
