---
import PageLayout from '../layouts/PageLayout.astro';
import { siteConfig, popularPostSlugs } from '../config';
import { Image } from 'astro:assets';
import headshotImage from '../../assets/img/headshot.jpg';
import ContactLinks from '../components/ContactLinks.astro';
import { getBioParagraphs, aboutContent } from '../content/about-bio';
import { getCollection, type CollectionEntry } from 'astro:content';
import { getPostUrl, getDateFromSlug, formatPostDate } from '../utils/post-urls';

const title = 'About';
const description = siteConfig.aboutDescription;

// Parse bio into structured sections
const bioParagraphs = getBioParagraphs(aboutContent);
const githubPara = bioParagraphs[0] || '';
const govPara = bioParagraphs[1] || '';
const eduPara = bioParagraphs[2] || '';

// Split the first paragraph into a short lede and detailed GitHub career history
const splitIndex = githubPara.indexOf('Previously,');
const lede = splitIndex > 0 ? githubPara.slice(0, splitIndex).trim() : githubPara;
const githubDetails = splitIndex > 0 ? githubPara.slice(splitIndex) : '';

// Fetch popular posts by slug
interface PostItem { postDate: Date; title: string; url: string }
function renderPost(post: CollectionEntry<'posts'>): PostItem {
  const postDate = getDateFromSlug(post.id);
  return { postDate, title: post.data.title, url: getPostUrl(post.id) };
}

const allPosts = await getCollection('posts');
const popularPostItems: PostItem[] = popularPostSlugs
  .map(slug => allPosts.find((post: CollectionEntry<'posts'>) => post.id === slug))
  .filter((p): p is CollectionEntry<'posts'> => p !== undefined)
  .map(renderPost);
---

<PageLayout title={title} description={description}>
  <div>
    <div class="float-right ml-6 mb-4 max-w-[200px] md:max-w-[250px]">
      <a href={`${siteConfig.githubRepoUrl}/raw/master/assets/img/headshot.jpg`}>
        <Image src={headshotImage} alt={`${siteConfig.author} headshot`} width={250} height={250} layout="fixed" class="w-full rounded" />
      </a>
    </div>

    <p class="text-lg leading-relaxed" set:html={lede}></p>

    <aside aria-label="At a glance" class="not-prose my-4 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800/50 px-5 py-4">
      <p class="text-xs font-semibold uppercase tracking-wide text-gray-700 dark:text-gray-400 mb-3">At a Glance</p>
      <dl class="grid grid-cols-1 sm:grid-cols-3 gap-x-6 gap-y-3 text-sm m-0">
        <div>
          <dt class="font-medium text-gray-700 dark:text-gray-400">Role</dt>
          <dd class="m-0 text-gray-900 dark:text-gray-100">{siteConfig.jobTitle}, {siteConfig.employer}</dd>
        </div>
        <div>
          <dt class="font-medium text-gray-700 dark:text-gray-400">Location</dt>
          <dd class="m-0 text-gray-900 dark:text-gray-100">Washington, DC</dd>
        </div>
        <div>
          <dt class="font-medium text-gray-700 dark:text-gray-400">Education</dt>
          <dd class="m-0 text-gray-900 dark:text-gray-100">JD & MBA, George Washington University</dd>
        </div>
      </dl>
      <div class="mt-3 flex gap-4 text-sm border-t border-gray-200 dark:border-gray-700 pt-3">
        <a href="/resume/" class="text-primary dark:text-primary-300 hover:underline">Full resume →</a>
        <a href="/talks/" class="text-primary dark:text-primary-300 hover:underline">Talks & media →</a>
      </div>
    </aside>
  </div>

  <h2 class="clear-both">At GitHub</h2>
  <p set:html={githubDetails}></p>

  <h2>In Government</h2>
  <p set:html={govPara}></p>

  <h2>Education</h2>
  <p set:html={eduPara}></p>

  <section class="not-prose mt-6 pt-6 border-t border-gray-200 dark:border-gray-700">
    <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-1">Popular Writing</h2>
    <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">Most-read posts from the blog.</p>
    <ul class="space-y-1.5 list-none p-0 m-0">
      {popularPostItems.map(({ postDate, title, url }) => (
        <li class="flex items-baseline gap-3">
          <time datetime={postDate.toISOString()} class="text-sm text-gray-600 dark:text-gray-400 shrink-0 w-[7.5rem] tabular-nums">{formatPostDate(postDate)}</time>
          <a href={url} class="text-primary hover:text-primary-700 dark:text-primary-300 dark:hover:text-primary-200 transition-colors duration-200">{title}</a>
        </li>
      ))}
    </ul>
    <p class="mt-3">
      <a href="/posts/" class="inline-flex items-center gap-1 rounded-lg border border-primary text-primary px-3 py-1.5 text-xs font-medium no-underline hover:bg-primary hover:text-white dark:border-primary-300 dark:text-primary-300 dark:hover:bg-primary-300 dark:hover:text-gray-900 transition-colors duration-200">View all posts →</a>
    </p>
  </section>

  <section class="not-prose mt-6 pt-6 border-t border-gray-200 dark:border-gray-700">
    <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-3">Get in Touch</h2>
    <p class="text-gray-700 dark:text-gray-300 mb-2">
      Feel free to email him at <a href={`mailto:${siteConfig.email}`} class="text-primary dark:text-primary-300 hover:underline">{siteConfig.email}</a> or find him on these networks:
    </p>
    <ContactLinks />
  </section>
</PageLayout>
