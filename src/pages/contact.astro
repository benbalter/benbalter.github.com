---
import PageLayout from '../layouts/PageLayout.astro';
import { siteConfig } from '../config';
import ContactLinks from '../components/ContactLinks.astro';

const title = 'Contact';
const description = `Contact ${siteConfig.author} via email or social media`;
---

<PageLayout title={title} description={description}>
  <div class="max-w-2xl mx-auto">
    <p class="text-lg text-gray-700 dark:text-gray-300 mb-8">
      The best way to reach me is via email at <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>. I'm also <code>@{siteConfig.socialUsername}</code> most places online:
    </p>

    <ContactLinks />

    <section class="mt-10 pt-8 border-t border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-4">A few things to know</h2>
      <ul class="space-y-3 text-gray-700 dark:text-gray-300 list-none p-0 m-0">
        <li class="flex gap-3">
          <span class="text-gray-400 dark:text-gray-500 shrink-0">📝</span>
          <span>If you're writing about something I've posted, feel free to quote anything on this site with attribution.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-gray-400 dark:text-gray-500 shrink-0">🎤</span>
          <span>Interested in having me speak? Check out my <a href="/talks/">past talks</a> for topics and formats.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-gray-400 dark:text-gray-500 shrink-0">💼</span>
          <span>For professional background, see my <a href="/resume/">resume</a> or <a href="/about/">about page</a>.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-gray-400 dark:text-gray-500 shrink-0">🔑</span>
          <span>Need to send something securely? Use my <a href="/key.asc">PGP key</a>.</span>
        </li>
      </ul>
    </section>
  </div>
</PageLayout>
