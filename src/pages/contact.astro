---
import PageLayout from '../layouts/PageLayout.astro';
import { siteConfig } from '../config';
import ContactLinks from '../components/ContactLinks.astro';

const title = 'Contact Ben Balter';
const description = `Get in touch with ${siteConfig.author}. Reach out via email, Bluesky, LinkedIn, GitHub, or other social channels to discuss technology leadership, open source, or collaboration.`;
---

<PageLayout title={title} description={description}>
  <div class="max-w-2xl mx-auto">
    <p class="text-lg text-gray-700 dark:text-gray-300 mb-8">
      The best way to reach me is via email at <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>. I'm also <code>@{siteConfig.socialUsername}</code> most places online:
    </p>

    <ContactLinks />
  </div>
</PageLayout>
