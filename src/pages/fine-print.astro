---
import PageLayout from "../layouts/PageLayout.astro";
import { siteConfig } from "../config";
import { Image } from "astro:assets";
import ccLicenseImage from "../../assets/images/cc-by-88x31.png";

const title = "Fine Print";
const description =
  "This is my personal Web site. The opinions expressed herein represent my own, and not those of any employer, group, or organization.";
---

<PageLayout title={title} description={description}>
  <div class="not-prose space-y-8">

    {/* Disclaimer Cards */}
    <div class="grid gap-4 md:grid-cols-2">
      <div class="rounded-lg border border-gray-200 dark:border-gray-700 p-5">
        <div class="flex items-start gap-3">
          <span class="text-xl shrink-0 mt-0.5" aria-hidden="true">💬</span>
          <div>
            <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-1.5">Personal opinions</h3>
            <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed m-0">
              This is my personal site. The opinions expressed herein represent my own, and not those of any employer, group, or organization.
            </p>
          </div>
        </div>
      </div>

      <div class="rounded-lg border border-gray-200 dark:border-gray-700 p-5">
        <div class="flex items-start gap-3">
          <span class="text-xl shrink-0 mt-0.5" aria-hidden="true">⚖️</span>
          <div>
            <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-1.5">Not legal advice</h3>
            <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed m-0">
              I am not an expert. My views do not constitute legal advice, nor is their validity, accuracy, currentness, or completeness guaranteed. If you need a lawyer, please find a licensed attorney in your state.
            </p>
          </div>
        </div>
      </div>

      <div class="rounded-lg border border-gray-200 dark:border-gray-700 p-5">
        <div class="flex items-start gap-3">
          <span class="text-xl shrink-0 mt-0.5" aria-hidden="true">🛒</span>
          <div>
            <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-1.5">Affiliate links</h3>
            <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed m-0">
              As an Amazon Associate I earn from qualifying purchases. Some external links, for example, book recommendations, may contain an affiliate code, meaning at no additional cost to you, I may earn a small commission if you click through and make a purchase.
            </p>
          </div>
        </div>
      </div>

      <div class="rounded-lg border border-gray-200 dark:border-gray-700 p-5">
        <div class="flex items-start gap-3">
          <span class="text-xl shrink-0 mt-0.5" aria-hidden="true">✍️</span>
          <div>
            <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-1.5">Oxford comma enthusiast</h3>
            <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed m-0">
              I am a strong proponent of the <a href="https://en.wikipedia.org/wiki/Serial_comma" class="text-primary dark:text-primary-300 hover:text-primary-700 dark:hover:text-primary-200 underline">serial comma</a>, and, well, commas in general.
            </p>
          </div>
        </div>
      </div>
    </div>

    {/* Licensing Section */}
    <section>
      <div class="flex items-baseline gap-3 border-l-4 border-primary pl-4 mb-6">
        <h3 class="text-2xl font-semibold text-gray-900 dark:text-gray-100 m-0">Licensing</h3>
      </div>

      <div class="rounded-lg border border-gray-200 dark:border-gray-700 p-6">
        <div class="flex justify-center mb-5">
          <a rel="license" href="https://creativecommons.org/licenses/by/3.0/" class="inline-block hover:opacity-80 transition-opacity duration-200">
            <Image src={ccLicenseImage} alt="Creative Commons Attribution 3.0 License" layout="fixed" />
          </a>
        </div>

        <ul class="space-y-3 text-sm text-gray-600 dark:text-gray-300 leading-relaxed list-none p-0 m-0">
          <li class="flex items-start gap-2.5">
            <span class="text-primary dark:text-primary-300 shrink-0 mt-0.5" aria-hidden="true">📝</span>
            <span>
              All original content on <code class="rounded bg-gray-100 dark:bg-gray-700 px-1.5 py-0.5 text-xs font-mono text-gray-800 dark:text-gray-200">Ben.Balter.com</code>
              <strong>other</strong> than <a href="/2026/03/04/thirteen-years-at-github/" class="text-primary dark:text-primary-300 hover:text-primary-700 dark:hover:text-primary-200 underline">the post "I've worked remotely at GitHub for thirteen years: here's what actually works"</a>
              is licensed under a <a rel="license" href="https://creativecommons.org/licenses/by/3.0/" class="text-primary dark:text-primary-300 hover:text-primary-700 dark:hover:text-primary-200 underline">Creative Commons Attribution 3.0 Unported License</a> attributable to {siteConfig.author}.
            </span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-primary dark:text-primary-300 shrink-0 mt-0.5" aria-hidden="true">📷</span>
            <span>Header image courtesy <a href="https://fedscoop.com/" class="text-primary dark:text-primary-300 hover:text-primary-700 dark:hover:text-primary-200 underline">FedScoop</a>, © 2013.</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-primary dark:text-primary-300 shrink-0 mt-0.5" aria-hidden="true">💻</span>
            <span>All code available <a href={siteConfig.githubRepoUrl} class="text-primary dark:text-primary-300 hover:text-primary-700 dark:hover:text-primary-200 underline">on GitHub</a> and licensed under the MIT license.</span>
          </li>
        </ul>
      </div>
    </section>
  </div>
</PageLayout>
